@model PaginatedList<PhonePalace.Domain.Entities.Accessory>
@using PhonePalace.Web.Helpers

@{
    ViewData["Title"] = "Accesorios";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Registrar Nuevo Accesorio</a>
</p>
<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center">
            <label class="form-label mb-0">Mostrar:</label>
            <select name="pageSize" class="form-select" style="width: auto;" onchange="this.form.submit()">
                @{ int pageSize = (int)(ViewData["PageSize"] ?? 10); }
                <option value="10" selected="@(pageSize == 10)">10</option>
                <option value="20" selected="@(pageSize == 20)">20</option>
                <option value="50" selected="@(pageSize == 50)">50</option>
                <option value="100" selected="@(pageSize == 100)">100</option>
            </select>
        </form>
    </div>
</div>
<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Imagen</th>
                        <th>Marca</th>
                        <th>Categoría</th>
                        <th>Precio</th>
                        <th>SKU</th>
                        <th>Código</th>
                        <th>Activo</th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var item in Model) {
                    <tr class="@(item.IsActive ? "" : "table-danger")">
                        <td>
                            @Html.DisplayFor(modelItem => item.Name)
                        </td>
                        <td>
                            <img src="@ImageHelper.GetImageUrl(item.Images)" alt="Imagen de @item.Name" class="product-image-thumbnail" />
                        </td>
                        <td>
                            @(item.Brand?.Name ?? "N/A")
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Category.Name)
                        </td>
                        <td>
                            @item.Price.ToString("C")
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.SKU)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Code)
                        </td>
                        <td>
                            <input type="checkbox" class="form-check-input" disabled @(item.IsActive ? "checked" : "") />
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.ProductID" class="btn btn-sm btn-warning">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.ProductID" class="btn btn-sm btn-info">Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.ProductID" class="btn btn-sm btn-danger">Eliminar</a>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-center align-items-center mt-3">
    @{
        var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
        var nextDisabled = !Model.HasNextPage ? "disabled" : "";
    }
    <a asp-action="Index"
       asp-route-pageNumber="@(Model.PageIndex - 1)"
       asp-route-pageSize="@ViewData["PageSize"]"
       class="btn btn-outline-secondary @prevDisabled">
        Anterior
    </a>
    <span class="mx-3">Página @Model.PageIndex de @Model.TotalPages</span>
    <a asp-action="Index"
       asp-route-pageNumber="@(Model.PageIndex + 1)"
       asp-route-pageSize="@ViewData["PageSize"]"
       class="btn btn-outline-secondary @nextDisabled">
        Siguiente
    </a>
</div>