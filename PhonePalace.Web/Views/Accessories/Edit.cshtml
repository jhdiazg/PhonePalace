@using PhonePalace.Domain.Enums
@model PhonePalace.Web.ViewModels.AccessoryViewModel

@{
    ViewData["Title"] = "Editar Accesorio";
}

<h1>@ViewData["Title"]</h1>

<h4>@Model.Name</h4>
<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ProductID" />
            <div class="mb-3 form-check">
                <input class="form-check-input" asp-for="IsActive" />
                <label class="form-check-label" asp-for="IsActive"></label>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="SKU" class="form-label"></label>
                    <input asp-for="SKU" class="form-control" />
                    <span asp-validation-for="SKU" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="CategoryID" class="form-label">Categoría</label>
                    <select asp-for="CategoryID" class="form-select" asp-items="ViewBag.CategoryID"></select>
                    <span asp-validation-for="CategoryID" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="BrandID" class="form-label">Marca (Opcional)</label>
                    <select asp-for="BrandID" class="form-select" asp-items="ViewBag.BrandID">
                        <option value="">-- Sin Marca --</option>
                    </select>
                    <span asp-validation-for="BrandID" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Price" class="form-label">Precio Venta</label>
                    <input asp-for="Price" class="form-control" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Cost" class="form-label">Costo</label>
                    <input asp-for="Cost" class="form-control" />
                    <span asp-validation-for="Cost" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Color" class="form-label"></label>
                    <input asp-for="Color" class="form-control" />
                    <span asp-validation-for="Color" class="text-danger"></span>
                </div>
                <div class="col-md-4 mb-3">
                    <label asp-for="ProductCondition" class="form-label">Condición del Producto</label>
                    <select asp-for="ProductCondition" class="form-select" asp-items="@(new SelectList(Enum.GetValues(typeof(ProductCondition))))"><option value="">-- Seleccione una Condición --</option></select>
                    <span asp-validation-for="ProductCondition" class="text-danger"></span>
                </div>
                 <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="Material" class="form-label"></label>
                        <input asp-for="Material" class="form-control" />
                        <span asp-validation-for="Material" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="mb-3">
                        <label asp-for="Compatibility" class="form-label">Compatibilidad</label>
                        <textarea asp-for="Compatibility" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Compatibility" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <hr />
            <h5>Imágenes del Producto</h5>

            <div class="mb-3">
                <label asp-for="NewImageFile" class="form-label"></label>
                <input asp-for="NewImageFile" class="form-control" type="file" accept="image/*" />
                <span asp-validation-for="NewImageFile" class="text-danger"></span>
            </div>

            @if (Model.Images.Any())
            {
                <div class="row">
                    @foreach (var image in Model.Images)
                    {
                        <div class="col-md-3 mb-3 text-center">
                            <img src="@image.ImageUrl" class="img-thumbnail" style="width: 150px; height: 150px; object-fit: cover;" alt="Imagen del producto" />
                            <div class="mt-2">
                                @if (!image.IsPrimary)
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-success image-action-button" formaction="@Url.Action("SetPrimaryImage")" data-image-id="@image.ProductImageID" data-product-id="@Model.ProductID" title="Marcar como principal">
                                        <i class="fas fa-star"></i>
                                    </button>
                                }
                                <button type="submit" class="btn btn-sm btn-outline-danger image-action-button" formaction="@Url.Action("DeleteImage")" data-image-id="@image.ProductImageID" data-product-id="@Model.ProductID" title="Eliminar imagen" onclick="return confirm('¿Está seguro de que desea eliminar esta imagen?');">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="mb-3">
                <input type="submit" value="Guardar" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const imageGallery = document.querySelector('.row'); // Contenedor de la galería
            imageGallery.addEventListener('click', function (event) {
                const button = event.target.closest('.image-action-button');
                if (button) {
                    event.preventDefault();
                    const form = button.closest('form');
                    const formData = new FormData(form);
                    formData.append('imageId', button.dataset.imageId);
                    formData.append('productId', button.dataset.productId);

                    fetch(button.formAction, {
                        method: 'POST',
                        body: new URLSearchParams(formData),
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    }).then(response => {
                        if (response.ok) {
                            window.location.reload();
                        } else {
                            alert('Error al procesar la solicitud.');
                        }
                    });
                }
            });
        });
    </script>
}