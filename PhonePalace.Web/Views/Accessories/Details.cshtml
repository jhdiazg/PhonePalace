@model PhonePalace.Domain.Entities.Accessory
@using PhonePalace.Web.Helpers
@using PhonePalace.Domain.Enums

@{
    ViewData["Title"] = "Detalles del Accesorio";
}

<h1>@ViewData["Title"]</h1>

<div>
    <h4>@Model.Name</h4>
    <hr />
    <div class="row">
        <div class="col-md-4 mb-3">
            <img src="@ImageHelper.GetImageUrl(Model.Images)" alt="Imagen de @Model.Name" class="img-fluid rounded shadow-sm" />
        </div>
        <div class="col-md-8">
            <dl class="row">
                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.SKU)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.SKU)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Description)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Description)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Price)</dt>
                <dd class="col-sm-8">@Model.Price.ToString("C")</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Cost)</dt>
                <dd class="col-sm-8">@Model.Cost.ToString("C")</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Brand)</dt>
                <dd class="col-sm-8">@(Model.Brand?.Name ?? "N/A")</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Category)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Category.Name)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Color)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Color)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.Material)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.Material)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.ProductCondition)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(model => model.ProductCondition)</dd>

                <dt class="col-sm-4">@Html.DisplayNameFor(model => model.IsActive)</dt>
                <dd class="col-sm-8">
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactivo</span>
                    }
                </dd>

                <dt class="col-sm-12">@Html.DisplayNameFor(model => model.Compatibility)</dt>
                <dd class="col-sm-12">@Html.DisplayFor(model => model.Compatibility)</dd>
            </dl>
        </div>
    </div>

    <h5 class="mt-4">Proyección de Costo</h5>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Porcentaje de Incremento</th>
                <th>Costo Proyectado</th>
            </tr>
        </thead>
        <tbody>
            @{
                var percentages = new List<double> { 0.20, 0.35, 0.60, 0.70, 0.80, 1.00, 1.50 };
                foreach (var p in percentages)
                {
                    var projectedCost = Model.Cost * (1m + (decimal)p);
                    <tr>
                        <td>@(p * 100)%</td>
                        <td>@projectedCost.ToString("C")</td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <div class="form-group mt-4">
        <label for="customCost">Calcular Porcentaje de Incremento para un Costo Personalizado:</label>
        <div class="row">
            <div class="col-md-4">
                <div class="input-group">
                    <input type="text" id="customCost" class="form-control" style="max-width: 180px;" />
                    <div class="input-group-append">
                        <span class="input-group-text">% de Incremento:&nbsp;&nbsp;<span id="calculatedPercentage">0.00</span>%</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.ProductID" class="btn btn-secondary">Editar</a> 
    <a asp-action="Index" class="btn btn-outline-secondary">Volver a la lista</a>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const baseCost = parseFloat('@Model.Cost.ToString(System.Globalization.CultureInfo.InvariantCulture)');
            const maxCost = baseCost * 2.5; // 150% increase
            const customCostInput = document.getElementById('customCost');
            const calculatedPercentageSpan = document.getElementById('calculatedPercentage');

            const currencyFormatter = new Intl.NumberFormat('es-CO', {
                style: 'currency',
                currency: 'COP',
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });

            function formatAsCurrency(value) {
                return currencyFormatter.format(value);
            }

            function parseFromCurrency(value) {
                if (typeof value !== 'string') return value;
                return parseFloat(value.replace(/\$/g, '').replace(/\./g, '').replace(',', '.').trim());
            }

            function calculateAndDisplayPercentage(cost) {
                let numCost = parseFloat(cost);
                if (isNaN(numCost) || baseCost === 0) {
                    calculatedPercentageSpan.textContent = '0.00';
                    return;
                }
                const percentage = ((numCost - baseCost) / baseCost) * 100;
                calculatedPercentageSpan.textContent = percentage.toFixed(2);
            }

            // Event listener for dynamic calculation while typing
            customCostInput.addEventListener('input', () => {
                let currentValue = parseFloat(customCostInput.value);
                if (isNaN(currentValue)) {
                    currentValue = 0; // Default to 0 if not a number
                }
                // Clamp the value between 0 and maxCost for calculation and display
                currentValue = Math.max(0, Math.min(currentValue, maxCost));
                // Do NOT update customCostInput.value here with toFixed(2) or it restricts typing
                calculateAndDisplayPercentage(currentValue);
            });

            // On focus, switch to a raw number for easy editing
            customCostInput.addEventListener('focus', function () {
                this.type = 'number';
                this.min = 0;
                this.max = maxCost;
                this.step = '0.01'; // Set a more appropriate step for currency
                this.value = parseFromCurrency(this.value).toFixed(2);
            });

            // On blur, format back to currency string and finalize value
            customCostInput.addEventListener('blur', function () {
                let currentValue = parseFloat(this.value);
                if (isNaN(currentValue)) {
                    currentValue = baseCost;
                }
                // Clamp the value between 0 and maxCost on blur as well
                currentValue = Math.max(0, Math.min(currentValue, maxCost));
                this.type = 'text';
                this.value = formatAsCurrency(currentValue);
                calculateAndDisplayPercentage(currentValue); // Final update
            });

            // Initial state
            customCostInput.type = 'text';
            customCostInput.value = formatAsCurrency(@Model.Cost.ToString(System.Globalization.CultureInfo.InvariantCulture));
            calculateAndDisplayPercentage(@Model.Cost.ToString(System.Globalization.CultureInfo.InvariantCulture));
        });
    </script>
}