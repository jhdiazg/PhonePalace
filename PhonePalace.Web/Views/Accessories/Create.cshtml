﻿
@using PhonePalace.Domain.Enums
@model PhonePalace.Web.ViewModels.AccessoryViewModel

@{
    ViewData["Title"] = "Registrar Accesorio";
}

<h1>@ViewData["Title"]</h1>

<h4>Nuevo Accesorio</h4>
<hr />
<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="SKU" class="form-label"></label>
                        <input asp-for="SKU" class="form-control" />
                        <span asp-validation-for="SKU" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="CategoryID" class="form-label"></label>
                        <select asp-for="CategoryID" class="form-select" asp-items="ViewBag.CategoryID"><option value="">-- Seleccione una Categoría --</option></select>
                        <span asp-validation-for="CategoryID" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="BrandID" class="form-label"></label>
                        <select asp-for="BrandID" class="form-select" asp-items="ViewBag.BrandID"><option value="">-- Sin Marca --</option></select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="Price" class="form-label"></label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="Cost" class="form-label"></label>
                        <input asp-for="Cost" class="form-control" />
                        <span asp-validation-for="Cost" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="Color" class="form-label"></label>
                        <input asp-for="Color" class="form-control" />
                        <span asp-validation-for="Color" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="ProductCondition" class="form-label"></label>
                        <select asp-for="ProductCondition" class="form-select" asp-items="@(new SelectList(Enum.GetValues(typeof(ProductCondition))))"><option value="">-- Seleccione una Condición --</option></select>
                        <span asp-validation-for="ProductCondition" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="Material" class="form-label"></label>
                        <input asp-for="Material" class="form-control" />
                        <span asp-validation-for="Material" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-12">
                    <div class="mb-3">
                        <label asp-for="Compatibility" class="form-label"></label>
                        <textarea asp-for="Compatibility" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Compatibility" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="NewImageFile" class="form-label"></label>
                <input asp-for="NewImageFile" class="form-control" type="file" accept="image/*" />
                <span asp-validation-for="NewImageFile" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input type="submit" value="Crear" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}