@model List<PhonePalace.Web.ViewModels.FixedExpenseStatusViewModel>
@using PhonePalace.Domain.Enums
@using PhonePalace.Web.Helpers
@using System.Globalization

@{
    ViewData["Title"] = "Gastos Fijos Mensuales";
}

<h1>@ViewData["Title"]</h1>
<p>Catálogo de conceptos de gastos fijos y registro de pagos.</p>

<div class="card shadow-sm mb-3">
    <div class="card-body">
            <div class="text-end">
                <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle-fill me-2"></i>Crear Nuevo Gasto</a>
            </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th>Concepto</th>
                <th>Monto por Defecto</th>
                <th>Pagado este Mes</th>
                <th>Último Pago Registrado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                decimal totalPagado = 0;
                var totals = ViewBag.CurrentMonthTotals as Dictionary<int, decimal>;
                if (totals != null && item.FixedExpense != null && totals.ContainsKey(item.FixedExpense.Id))
                {
                    totalPagado = totals[item.FixedExpense.Id];
                }
                <tr>
                    <td>@item.FixedExpense?.Concept</td>
                    <td>@item.FixedExpense?.Amount.ToString("C")</td>
                    <td>
                        <span class="@(totalPagado >= item.FixedExpense?.Amount ? "text-success fw-bold" : "")">@totalPagado.ToString("C")</span>
                    </td>
                    <td>
                        @if(item.LastPayment != null) {
                            <div>
                                <span class="fw-bold">@item.LastPayment.Period.ToString("MMMM yyyy").ToUpper()</span>
                                <br/>
                                <small class="text-muted">Pagado el @item.LastPayment.PaymentDate.ToShortDateString() (@item.LastPayment.Amount.ToString("C"))</small>
                            </div>
                        } else {
                            <span class="text-muted fst-italic">Sin pagos registrados</span>
                        }
                    </td>
                    <td class="text-end">
                        <div class="btn-group" role="group">
                            @if (totalPagado >= item.FixedExpense?.Amount)
                            {
                                <button type="button" class="btn btn-sm btn-secondary" disabled title="Gasto cubierto"><i class="bi bi-check-circle"></i> Pagado</button>
                            }
                            else
                            {
                                <a asp-action="Pay" asp-route-id="@item.FixedExpense?.Id" class="btn btn-sm btn-outline-success" title="Registrar Nuevo Pago"><i class="bi bi-currency-dollar"></i> Pagar</a>
                            }
                            <a asp-action="Details" asp-route-id="@item.FixedExpense?.Id" class="btn btn-sm btn-info text-white" title="Ver Historial"><i class="bi bi-clock-history"></i></a>
                            <a asp-action="Edit" asp-route-id="@item.FixedExpense?.Id" class="btn btn-sm btn-outline-primary" title="Editar Definición"><i class="bi bi-pencil-fill"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.FixedExpense?.Id" class="btn btn-sm btn-outline-danger" title="Eliminar Definición"><i class="bi bi-trash-fill"></i></a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>