@model PhonePalace.Domain.Entities.FixedExpense
@using PhonePalace.Domain.Entities
@using PhonePalace.Web.Helpers

@{
    ViewData["Title"] = "Detalles del Gasto Fijo";
    var payments = ViewBag.Payments as List<FixedExpensePayment>;
}

<h1>Detalles del Gasto Fijo</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h4 class="card-title">@Model.Concept</h4>
        <hr />
        <dl class="row mb-0">
            <dt class="col-sm-3">Concepto</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Concept)</dd>

            <dt class="col-sm-3">Monto Base (Mensual)</dt>
            <dd class="col-sm-9">@Model.Amount.ToString("C")</dd>

            <dt class="col-sm-3">Estado</dt>
            <dd class="col-sm-9">
                @if (Model.IsActive)
                {
                    <span class="badge bg-success">Activo</span>
                }
                else
                {
                    <span class="badge bg-secondary">Inactivo</span>
                }
            </dd>
        </dl>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-light">
        <h5 class="mb-0">Historial de Pagos</h5>
    </div>
    <div class="card-body p-0">
        @if (payments != null && payments.Any())
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha de Pago</th>
                            <th>Periodo</th>
                            <th>Monto</th>
                            <th>Método</th>
                            <th>Notas</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in payments)
                        {
                            <tr>
                                <td>@payment.PaymentDate.ToString("dd/MM/yyyy")</td>
                                <td>@payment.Period.ToString("MMMM yyyy").ToUpper()</td>
                                <td>@payment.Amount.ToString("C")</td>
                                <td>@EnumHelper.GetDisplayName(payment.PaymentMethod)</td>
                                <td>@payment.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="p-3 text-center text-muted">No hay pagos registrados para este gasto.</div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Volver a la Lista</a>
</div>