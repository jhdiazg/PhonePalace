@model PhonePalace.Web.Helpers.PaginatedList<PhonePalace.Domain.Entities.AccountPayable>
@using PhonePalace.Web.Helpers

@{
    ViewData["Title"] = "Cuentas por Pagar";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">Filtros</h5>
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label for="startDate" class="form-label">Fecha Vencimiento (Desde)</label>
                <input type="date" name="startDate" id="startDate" value="@ViewData["StartDate"]" class="form-control" />
            </div>
            <div class="col-md-3">
                <label for="endDate" class="form-label">Fecha Vencimiento (Hasta)</label>
                <input type="date" name="endDate" id="endDate" value="@ViewData["EndDate"]" class="form-control" />
            </div>
            <div class="col-md-2">
                <label for="status" class="form-label">Estado</label>
                <select name="status" id="status" class="form-select" asp-items="ViewBag.StatusList"></select>
            </div>
            <div class="col-md-2">
                <label for="type" class="form-label">Tipo</label>
                <select name="type" id="type" class="form-select" asp-items="ViewBag.TypeList">
                    <option value="">Todos</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>Resultados</span>
        <a asp-action="Create" class="btn btn-success btn-sm">
            <i class="bi bi-plus-circle"></i> Crear CxP Manual
        </a>
    </div>
    <div class="card-body">
        <div class="mb-3 fw-bold">
            Total Pendiente (en esta consulta): @(ViewBag.TotalPayable != null ? ((decimal)ViewBag.TotalPayable).ToString("C") : "$0")
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Beneficiario / Proveedor</th>
                        <th>Documento</th>
                        <th>Tipo</th>
                        <th>Fecha Vencimiento</th>
                        <th class="text-end">Monto Total</th>
                        <th class="text-end">Saldo Pendiente</th>
                        <th class="text-center">Estado</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.DueDate.Date < DateTime.Today.Date && !item.IsPaid ? "table-danger" : "")">
                            <td>
                                @if (item.PurchaseId.HasValue)
                                {
                                    <a asp-controller="Purchases" asp-action="Details" asp-route-id="@item.PurchaseId">Compra #@item.PurchaseId</a>
                                }
                                else
                                {
                                    @item.Id
                                }
                            </td>
                            <td>
                                @(item.Purchase?.Supplier?.DisplayName ?? item.Beneficiary)
                            </td>
                            <td>
                                <small>@item.DocumentType @item.DocumentNumber</small>
                            </td>
                            <td>
                                <span class="badge bg-secondary">@item.Type</span>
                            </td>
                            <td>
                                @item.DueDate.ToString("dd/MM/yyyy")
                                @if (item.DueDate.Date < DateTime.Today.Date && !item.IsPaid)
                                {
                                    <span class="badge bg-danger ms-1">Vencida</span>
                                }
                            </td>
                            <td class="text-end">@item.Amount.ToString("C")</td>
                            <td class="text-end fw-bold">@item.Balance.ToString("C")</td>
                            <td class="text-center">
                                @if (item.IsPaid)
                                {
                                    <span class="badge bg-success">Pagada</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">Pendiente</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm" title="Ver Detalles y Pagos"><i class="bi bi-eye"></i></a>
                                @if (!item.IsPaid)
                                {
                                    <a asp-action="Pay" asp-route-id="@item.Id" class="btn btn-success btn-sm" title="Registrar Pago"><i class="bi bi-cash-coin"></i></a>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted">No se encontraron cuentas por pagar con los filtros seleccionados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <partial name="_Pagination" model="Model" />
    </div>
</div>