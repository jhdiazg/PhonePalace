@model IEnumerable<PhonePalace.Domain.Entities.AccountPayable>

@{
    ViewData["Title"] = "Cuentas por Pagar";
}

<h1>Cuentas por Pagar</h1>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Proveedor</th>
            <th>Tipo Documento</th>
            <th>No. Documento</th>
            <th>Monto</th>
            <th>Fecha Creación</th>
            <th>Fecha Vencimiento</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @(item.Purchase?.Supplier?.DisplayName ?? "N/A")
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.DocumentType)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.DocumentNumber)
                </td>
                <td>
                    @item.Amount.ToString("C")
                </td>
                <td>
                    @item.CreatedDate.ToString("dd/MM/yyyy")
                </td>
                <td>
                    @item.DueDate.ToString("dd/MM/yyyy")
                </td>
                <td>
                    @if (item.IsPaid)
                    {
                        <span class="badge bg-success">Pagada</span>
                    }
                    else if (item.DueDate < DateTime.Now)
                    {
                        <span class="badge bg-danger">Vencida</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pendiente</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalles</a>
                </td>
            </tr>
        }
    </tbody>
</table>