@model PhonePalace.Domain.Entities.AccountPayable
@using PhonePalace.Domain.Enums

@{
    ViewData["Title"] = "Registrar Cuenta por Pagar";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Nueva Cuenta por Pagar (Manual)</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Type" class="form-label fw-bold">Tipo de Obligación</label>
                            <select asp-for="Type" class="form-select">
                                <option value="Proveedor">Proveedor / Compra</option>
                                <option value="CreditoBancario">Crédito Bancario</option>
                                <option value="Impuestos">Impuestos</option>
                                <option value="Otros">Otros</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Beneficiary" class="form-label fw-bold"></label>
                            <select asp-for="Beneficiary" class="form-control" asp-items="ViewBag.Beneficiary">
                                <option value="">-- Seleccione un Proveedor --</option>
                            </select>
                            <span asp-validation-for="Beneficiary" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="DocumentType" class="form-label fw-bold"></label>
                                <select asp-for="DocumentType" class="form-select" asp-items="Html.GetEnumSelectList<AccountPayableDocumentType>()"></select>
                                <span asp-validation-for="DocumentType" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DocumentNumber" class="form-label fw-bold"></label>
                                <input asp-for="DocumentNumber" class="form-control" />
                                <span asp-validation-for="DocumentNumber" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="Amount" class="form-label fw-bold"></label>
                                <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="Amount" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DueDate" class="form-label fw-bold"></label>
                                <input asp-for="DueDate" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="DueDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" class="btn btn-secondary me-md-2">Cancelar</a>
                            <button type="submit" class="btn btn-success">Guardar Cuenta</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            $('#Beneficiary').select2({
                placeholder: "Seleccione o escriba un beneficiario",
                tags: true, // Esto permite seleccionar uno existente O escribir uno nuevo si no existe
                allowClear: true,
                theme: 'bootstrap-5'
            });
        });
    </script>
}