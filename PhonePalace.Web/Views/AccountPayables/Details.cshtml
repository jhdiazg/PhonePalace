@model PhonePalace.Domain.Entities.AccountPayable

@{
    ViewData["Title"] = "Detalles de Cuenta por Pagar";
}

<h1>Detalles de Cuenta por Pagar</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div>
    <h4>Información de la Cuenta</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">
            Proveedor
        </dt>
        <dd class="col-sm-9">
            @(Model.Purchase?.Supplier?.DisplayName ?? "N/A")
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.DocumentType)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.DocumentType)
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.DocumentNumber)
        </dt>
        <dd class="col-sm-9">
            @Html.DisplayFor(model => model.DocumentNumber)
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.Amount)
        </dt>
        <dd class="col-sm-9">
            @Model.Amount.ToString("C")
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.CreatedDate)
        </dt>
        <dd class="col-sm-9">
            @Model.CreatedDate.ToString("g")
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.DueDate)
        </dt>
        <dd class="col-sm-9">
            @Model.DueDate.ToString("d")
        </dd>
        <dt class="col-sm-3">
            @Html.DisplayNameFor(model => model.IsPaid)
        </dt>
        <dd class="col-sm-9">
            @if (Model.IsPaid)
            {
                <span class="badge bg-success">Pagada</span>
            }
            else
            {
                <span class="badge bg-warning text-dark">Pendiente</span>
            }
        </dd>
    </dl>
</div>

@if (Model.Payments != null && Model.Payments.Any())
{
    <div class="card shadow-sm mt-4 mb-4">
        <div class="card-header">
            <h4 class="mb-0"><i class="bi bi-list-ol"></i> Historial de Abonos</h4>
        </div>
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Monto Pagado</th>
                        <th>Método</th>
                        <th>Banco</th>
                        <th>Nota</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model.Payments.OrderByDescending(p => p.PaymentDate))
                    {
                        <tr>
                            <td>@payment.PaymentDate.ToString("g")</td>
                            <td>@payment.Amount.ToString("C")</td>
                            <td>@PhonePalace.Web.Helpers.EnumHelper.GetDisplayName(payment.PaymentMethod)</td>
                            <td>@(payment.Bank?.Name ?? "-")</td>
                            <td>@payment.Note</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (!Model.IsPaid)
{
    <div class="mt-4 mb-4">
        <a asp-action="Pay" asp-route-id="@Model.Id" class="btn btn-success btn-lg w-100">
            <i class="bi bi-cash-coin"></i> Abonar / Pagar
        </a>
    </div>
}

<div>
    <a asp-action="Index" class="btn btn-secondary">Volver a la Lista</a>
    @if (!Model.IsPaid && Model.PurchaseId > 0)
    {
        <a asp-controller="Purchases" asp-action="Details" asp-route-id="@Model.PurchaseId" class="btn btn-primary">Ir a Compra para Pagar</a>
    }
</div>

@section Scripts {
}