@model PhonePalace.Domain.Entities.Product

@{
    ViewData["Title"] = "Borrar Producto";
}

<h1>@ViewData["Title"]</h1>

<h3>¿Estás seguro de que quieres borrar este producto?</h3>
<div>
    <h4>
        @if (Model is CellPhone) { <span class="badge bg-primary">Celular</span> }
        else if (Model is Accessory) { <span class="badge bg-info text-dark">Accesorio</span> }
    </h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.SKU)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.SKU)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="ProductID" />
        <input type="submit" value="Borrar" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
    </form>
</div>