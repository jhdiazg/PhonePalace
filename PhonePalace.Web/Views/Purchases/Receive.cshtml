@model PhonePalace.Web.ViewModels.PurchaseReceiveViewModel

@{
    ViewData["Title"] = "Recibir Compra";
}

<h1>Recibir Compra #@Model.PurchaseId</h1>
<h4>Proveedor: @Model.SupplierName</h4>
<hr />

<form asp-action="Receive" method="post">
    <input type="hidden" asp-for="PurchaseId" />
    <input type="hidden" asp-for="SupplierName" />

    <div class="row mb-3">
        <div class="col-md-4">
            <div class="form-group">
                <label asp-for="DocumentType" class="control-label"></label>
                <select asp-for="DocumentType" class="form-control" asp-items="Html.GetEnumSelectList<PhonePalace.Domain.Enums.AccountPayableDocumentType>()"></select>
            </div>
        </div>
        <div class="col-md-4">
            <div class="form-group">
                <label asp-for="SupplierInvoiceNumber" class="control-label"></label>
                <input asp-for="SupplierInvoiceNumber" class="form-control" placeholder="Ej: FAC-12345" required />
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">Detalle de Recepción</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped mb-0">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th class="text-center">Ordenado</th>
                        <th class="text-center">Recibido Prev.</th>
                        <th class="text-center">Pendiente</th>
                        <th style="width: 150px;">Recibir Ahora</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Details.Count; i++)
                    {
                        <tr>
                            <td>
                                <input type="hidden" asp-for="Details[i].PurchaseDetailId" />
                                <input type="hidden" asp-for="Details[i].ProductName" />
                                <input type="hidden" asp-for="Details[i].OrderedQuantity" />
                                <input type="hidden" asp-for="Details[i].PreviouslyReceivedQuantity" />
                                <input type="hidden" asp-for="Details[i].UnitPrice" />
                                @Model.Details[i].ProductName
                            </td>
                            <td class="text-center">@Model.Details[i].OrderedQuantity</td>
                            <td class="text-center">@Model.Details[i].PreviouslyReceivedQuantity</td>
                            <td class="text-center">@(Model.Details[i].OrderedQuantity - Model.Details[i].PreviouslyReceivedQuantity)</td>
                            <td>
                                <input asp-for="Details[i].QuantityToReceive" class="form-control" type="number" min="0" max="@(Model.Details[i].OrderedQuantity - Model.Details[i].PreviouslyReceivedQuantity)" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-success">Confirmar Recepción</button>
        <a asp-action="Details" asp-route-id="@Model.PurchaseId" class="btn btn-secondary">Cancelar</a>
    </div>
</form>