@model PhonePalace.Web.ViewModels.PurchaseCreateViewModel
@using PhonePalace.Domain.Entities

@{
    ViewData["Title"] = "Crear Compra";
}

<h1>Crear Compra</h1>

<hr />
<div class="row">
    <div class="col-md-12">
        <form asp-action="Create" id="purchase-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row">
                <div class="form-group col-md-6">
                    <label asp-for="SupplierId" class="control-label">Proveedor</label>
                    <select asp-for="SupplierId" class="form-control" asp-items="Model.Suppliers"></select>
                </div>
                <div class="form-group col-md-6">
                    <label asp-for="PaymentMethod" class="control-label"></label>
                    <select asp-for="PaymentMethod" class="form-control" asp-items="Html.GetEnumSelectList<PhonePalace.Domain.Enums.PurchasePaymentMethod>()"></select>
                </div>
            </div>
            <div class="row">
                <div class="form-group col-md-6">
                    <label asp-for="DocumentType" class="control-label"></label>
                    <select asp-for="DocumentType" class="form-control" asp-items="Html.GetEnumSelectList<PhonePalace.Domain.Enums.AccountPayableDocumentType>()"></select>
                </div>
                <div class="form-group col-md-6">
                    <label asp-for="SupplierInvoiceNumber" class="control-label"></label>
                    <input asp-for="SupplierInvoiceNumber" class="form-control" placeholder="Ej: FAC-12345" />
                </div>
            </div>
            <div class="form-group">
                <label asp-for="Observations" class="control-label"></label>
                <textarea asp-for="Observations" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Observations" class="text-danger"></span>
            </div>

            <h3>Productos</h3>
            <span asp-validation-for="Details" class="text-danger"></span>
            <div class="row align-items-end">
                <div class="form-group col-md-5">
                    <label for="category-select">Filtrar por Categoría</label>
                    <select id="category-select" class="form-control" asp-items="Model.Categories">
                        <option value="">Todas las categorías</option>
                    </select>
                </div>
                <div class="form-group col-md-5">
                    <label for="product-search">Buscar Producto</label>
                    <select id="product-search" class="form-control">
                        <option value="">-- Seleccione un Producto --</option>
                        @if (ViewBag.AllProducts != null)
                        {
                            foreach (var product in (IEnumerable<Product>)ViewBag.AllProducts)
                            {
                                <option value="@product.ProductID" data-category-id="@product.CategoryID">@product.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="form-group col-md-2">
                    <button type="button" id="add-product-btn" class="btn btn-success w-100">Agregar</button>
                </div>
            </div>
            <table class="table" id="purchase-details">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Precio Unitario</th>
                        <th>IVA</th>
                        <th>Subtotal</th>
                        <th>Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>

            <div class="form-group mt-3">
                <input type="submit" value="Crear" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            // Diccionario de productos para inicialización rápida (Requiere ViewBag.AllProducts en el Controlador)
            var allProductsDict = {};
            @if (ViewBag.AllProducts != null)
            {
                <text>
                allProductsDict = @Html.Raw(Json.Serialize(((IEnumerable<Product>)ViewBag.AllProducts).ToDictionary(
                    p => p.ProductID.ToString(),
                    p => new { id = p.ProductID, name = p.Name, price = p.Price, cost = p.Cost }
                )));
                </text>
            }

            $('#SupplierId').select2({
                placeholder: "Seleccione un proveedor",
                allowClear: true
            });

            // Guardar opciones originales para el filtrado
            const $productSelect = $('#product-search');
            const allProductOptions = $productSelect.html();

            $('#category-select').on('change', function() {
                const selectedCategoryId = $(this).val();
                
                // Destruir select2 para manipular el DOM
                if ($productSelect.data('select2')) {
                    $productSelect.select2('destroy');
                }

                // Restaurar opciones y filtrar
                $productSelect.html(allProductOptions);
                if (selectedCategoryId) {
                    $productSelect.find('option').filter(function() {
                        return $(this).val() !== '' && $(this).data('category-id') != selectedCategoryId;
                    }).remove();
                }

                // Reinicializar
                initProductSelect();
                $productSelect.val(null).trigger('change');
            });

            let detailIndex = 0;

            function initProductSelect() {
                $productSelect.select2({
                    placeholder: "Buscar un producto",
                    allowClear: true
                });
            }

            $('#add-product-btn').on('click', function () {
                var productId = $productSelect.val();
                if (!productId || !allProductsDict[productId]) {
                    alert("Por favor seleccione un producto.");
                    return;
                }

                    var data = allProductsDict[productId];
                    
                    // Usamos el Costo como precio unitario sugerido para compras
                    var unitPrice = parseFloat(data.cost) || 0.0;

                    let newRow = `
                        <tr>
                            <td>
                                <input type="hidden" name="Details[${detailIndex}].ProductId" value="${data.id}" />
                                ${data.name}
                            </td>
                            <td>
                                <input type="number" name="Details[${detailIndex}].Quantity" class="form-control quantity" value="1" min="1" />
                            </td>
                            <td>
                                <input type="number" name="Details[${detailIndex}].UnitPrice" class="form-control unit-price" value="${unitPrice.toFixed(2)}" step="0.01" />
                            </td>
                            <td>
                                <select name="Details[${detailIndex}].TaxRate" class="form-control tax-rate">
                                    <option value="0">0%</option>
                                    <option value="@Model.IVARate" selected>@(Model.IVARate)%</option>
                                </select>
                            </td>
                            <td class="subtotal">${unitPrice.toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 })}</td>
                            <td class="total">${(unitPrice * (1 + @Model.IVARate.ToString(System.Globalization.CultureInfo.InvariantCulture) / 100)).toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0})}</td>
                            <td>
                                <button type="button" class="btn btn-danger remove-detail">Eliminar</button>
                            </td>
                        </tr>`;
                    $("#purchase-details tbody").append(newRow);
                    detailIndex++;
                    $productSelect.val(null).trigger('change');
            });

            // Inicializar al cargar
            initProductSelect();

            $(document).on("click", ".remove-detail", function () {
                $(this).closest("tr").remove();
            });

            $(document).on('input', '.quantity, .unit-price, .tax-rate', function() {
                let row = $(this).closest('tr');
                let quantity = parseFloat(row.find('.quantity').val()) || 0;
                let unitPrice = parseFloat(row.find('.unit-price').val()) || 0;
                let taxRate = parseFloat(row.find('.tax-rate').val()) || 0;
                let subtotal = quantity * unitPrice;
                let taxAmount = subtotal * taxRate / 100;
                let total = subtotal + taxAmount;
                row.find('.subtotal').text(subtotal.toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 }));
                row.find('.total').text(total.toLocaleString('es-CO', { minimumFractionDigits: 0, maximumFractionDigits: 0 }));
            });
        });
    </script>
}
