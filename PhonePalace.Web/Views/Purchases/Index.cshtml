@model PaginatedList<PhonePalace.Domain.Entities.Purchase>
@using PhonePalace.Web.Helpers
@using PhonePalace.Domain.Enums

@{
    ViewData["Title"] = "Compras";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Registrar Nueva Compra</a>
</p>

<div class="card mb-3">
    <div class="card-header">
        <h5 class="mb-0">Filtros</h5>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get">
            <div class="row g-3">
                @* --- INICIO: Integración del selector de tamaño de página --- *@
                <div class="col-md-2">
                    <partial name="_PageSizeSelector" model='(int?)ViewData["PageSize"]' />
                </div>
                @* --- FIN: Integración del selector de tamaño de página --- *@
                <div class="col-md-2">
                    <label class="form-label">Buscar (Proveedor/ID)</label>
                    <input type="text" name="searchString" value="@(ViewData["SearchString"] ?? ViewData["CurrentFilter"])" class="form-control" placeholder="Nombre o ID..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha Inicio</label>
                    <input type="date" name="startDate" value="@(ViewData["StartDate"] ?? DateTime.Now.ToString("yyyy-MM-dd"))" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Fecha Fin</label>
                    <input type="date" name="endDate" value="@(ViewData["EndDate"] ?? DateTime.Now.ToString("yyyy-MM-dd"))" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Estado</label>
                    <select name="status" class="form-select">
                        <option value="">Todos</option>
                        @{
                            var currentStatus = ViewData["Status"] as PurchaseStatus?;
                        }
                        @foreach (var item in Html.GetEnumSelectList<PurchaseStatus>())
                        {
                            <option value="@item.Value" selected="@(item.Value == ((int?)currentStatus)?.ToString())">@item.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Filtrar</button>
                    <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Proveedor</th>
                        <th>Fecha de Compra</th>
                        <th>Monto Total</th>
                        <th>Estado</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var item in Model) {
                    <tr>
                        <td class="@(item.Status == PurchaseStatus.Cancelled ? "text-danger" : "")">@Html.DisplayFor(modelItem => item.Id)</td>
                        <td class="@(item.Status == PurchaseStatus.Cancelled ? "text-danger" : "")">@(item.Supplier?.DisplayName ?? "")</td>
                        <td class="@(item.Status == PurchaseStatus.Cancelled ? "text-danger" : "")">@item.PurchaseDate.ToString("dd/MM/yyyy")</td>
                        <td class="@(item.Status == PurchaseStatus.Cancelled ? "text-danger" : "")">@item.TotalAmount.ToString("C")</td>
                        <td class="@(item.Status == PurchaseStatus.Cancelled ? "text-danger" : "")">@Html.DisplayFor(modelItem => item.Status)</td>
                        <td class="text-end">
                            @if (item.Status == PurchaseStatus.Draft)
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                            }
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detalles</a>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-center align-items-center mt-3">
    @{
        var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
        var nextDisabled = !Model.HasNextPage ? "disabled" : "";
    }
    <a asp-action="Index"
       asp-route-pageNumber="@(Model.PageIndex - 1)"
       asp-route-searchString="@(ViewData["SearchString"] ?? ViewData["CurrentFilter"])"
       asp-route-startDate="@ViewData["StartDate"]"
       asp-route-endDate="@ViewData["EndDate"]"
       asp-route-status="@ViewData["Status"]"
       class="btn btn-outline-secondary @prevDisabled">
        Anterior
    </a>
    <span class="mx-3">Página @Model.PageIndex de @Model.TotalPages</span>
    <a asp-action="Index"
       asp-route-pageNumber="@(Model.PageIndex + 1)"
       asp-route-searchString="@(ViewData["SearchString"] ?? ViewData["CurrentFilter"])"
       asp-route-startDate="@ViewData["StartDate"]"
       asp-route-endDate="@ViewData["EndDate"]"
       asp-route-status="@ViewData["Status"]"
       class="btn btn-outline-secondary @nextDisabled">
        Siguiente
    </a>
</div>

@section Scripts {
    <script>
        document.querySelector('form').addEventListener('submit', function (e) {
            var startDate = document.querySelector('input[name="startDate"]').value;
            var endDate = document.querySelector('input[name="endDate"]').value;

            if (startDate && endDate && startDate > endDate) {
                e.preventDefault();
                alert('La fecha final no puede ser menor a la fecha inicial.');
            }
        });
    </script>
}