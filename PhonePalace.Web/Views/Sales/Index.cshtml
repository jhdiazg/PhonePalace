@model PaginatedList<PhonePalace.Domain.Entities.Invoice>
@using PhonePalace.Web.Helpers
@using PhonePalace.Domain.Enums

@{
    ViewData["Title"] = "Ventas";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Registrar Nueva Venta</a>
</p>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID Factura</th>
                        <th>Cliente</th>
                        <th>Fecha de Venta</th>
                        <th>Total</th>
                        <th>Estado</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var item in Model) {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.InvoiceID)</td>
                        <td>@Html.DisplayFor(modelItem => item.Client.DisplayName)</td>
                        <td>@item.SaleDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.Total.ToString("C")</td>
                        <td>
                            <span class="badge bg-@(item.Status == InvoiceStatus.Completed ? "success" : (item.Status == InvoiceStatus.Pending ? "warning" : "danger"))">@Html.DisplayFor(modelItem => item.Status)</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@item.InvoiceID" class="btn btn-sm btn-outline-info">Detalles</a>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-center align-items-center mt-3">
    @{
        var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
        var nextDisabled = !Model.HasNextPage ? "disabled" : "";
    }
    <a asp-action="Index"
       asp-route-pageNumber="@(Model.PageIndex - 1)"
       class="btn btn-outline-secondary @prevDisabled">
        Anterior
    </a>
    <span class="mx-3">Página @Model.PageIndex de @Model.TotalPages</span>
    <a asp-action="Index"
       asp-route-pageNumber="@(Model.PageIndex + 1)"
       class="btn btn-outline-secondary @nextDisabled">
        Siguiente
    </a>
</div>