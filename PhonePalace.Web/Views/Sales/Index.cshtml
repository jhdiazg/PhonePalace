@model PaginatedList<PhonePalace.Domain.Entities.Sale>
@using PhonePalace.Web.Helpers
@using PhonePalace.Domain.Entities

@{
    ViewData["Title"] = "Ventas";
    var pendingSaleIds = ViewData["PendingSaleIds"] as HashSet<int> ?? new HashSet<int>();
    var currentCashDate = ViewData["CurrentCashDate"] as DateTime?;
}

<h1>Listado de Ventas</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label for="startDate" class="form-label">Fecha Inicio</label>
                    <input type="date" id="startDate" name="startDate" value="@ViewData["StartDate"]" class="form-control">
                </div>
                <div class="col-md-2">
                    <label for="endDate" class="form-label">Fecha Fin</label>
                    <input type="date" id="endDate" name="endDate" value="@ViewData["EndDate"]" class="form-control">
                </div>
                <div class="col-md-3">
                    <label for="clientName" class="form-label">Nombre del Cliente</label>
                    <input type="text" id="clientName" name="clientName" value="@ViewData["ClientName"]" class="form-control" placeholder="Buscar por nombre...">
                </div>
                @if (!User.IsInRole("Contador"))
                {
                    <div class="col-md-2">
                        <label for="invoiceType" class="form-label">Tipo Factura</label>
                        @Html.DropDownList("invoiceType", (IEnumerable<SelectListItem>)ViewBag.InvoiceTypes, new { @class = "form-select", onchange = "this.form.submit();" })
                    </div>
                }
                <div class="col-md-1">
                    <label for="pageSize" class="form-label">Registros</label>
                    <select id="pageSize" name="pageSize" class="form-select" onchange="this.form.submit()">
                        @{ int pSize = (int)(ViewData["PageSize"] ?? 10); }
                        <option value="10" selected="@(pSize == 10)">10</option>
                        <option value="20" selected="@(pSize == 20)">20</option>
                        <option value="50" selected="@(pSize == 50)">50</option>
                        <option value="100" selected="@(pSize == 100)">100</option>
                    </select>
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">Filtrar</button>
                    <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle-fill me-2"></i>Nueva Venta</a>
    </div>
    <div class="text-end">
        <span class="fw-bold">Total Consulta:</span>
        <span class="badge bg-dark fs-6">@(((decimal?)ViewData["Total"] ?? 0).ToString("C"))</span>
        <span class="fw-bold ms-3">Utilidad Total:</span>
        <span class="badge bg-success fs-6">@(((decimal?)ViewData["TotalProfit"] ?? 0).ToString("C"))</span>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th>Factura</th>
                <th>Fecha</th>
                <th>Cliente</th>
                <th class="text-end">Total</th>
                <th class="text-end">Utilidad</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var profit = item.Details.Sum(d => d.Quantity * (d.UnitPrice - (d.Product?.Cost ?? 0)));
                <tr>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.SaleID"><strong>@item.Invoice.InvoiceID</strong></a>
                    </td>
                    <td>@item.SaleDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>@Html.DisplayFor(modelItem => item.Client.DisplayName)</td>
                    <td class="text-end">@item.Invoice.Total.ToString("C")</td>
                    <td class="text-end text-success">@profit.ToString("C")</td>
                    <td class="text-center">
                        @if (pendingSaleIds.Contains(item.SaleID))
                        {
                            <span class="badge bg-warning text-dark" title="Venta a crédito con saldo pendiente"><i class="bi bi-hourglass-split"></i> Crédito</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<div class="d-flex justify-content-center align-items-center mt-3">
    <a asp-action="Index"
       asp-route-pageNumber="@(Model.PageIndex - 1)"
       asp-route-pageSize="@ViewData["PageSize"]"
       asp-route-startDate="@ViewData["StartDate"]"
       asp-route-endDate="@ViewData["EndDate"]"
       asp-route-clientName="@ViewData["ClientName"]"
       class="btn btn-secondary @prevDisabled">
        Anterior
    </a>
    <span class="mx-3">Página @Model.PageIndex de @Model.TotalPages</span>
    <a asp-action="Index"
       asp-route-pageNumber="@(Model.PageIndex + 1)"
       asp-route-pageSize="@ViewData["PageSize"]"
       asp-route-startDate="@ViewData["StartDate"]"
       asp-route-endDate="@ViewData["EndDate"]"
       asp-route-clientName="@ViewData["ClientName"]"
       class="btn btn-secondary @nextDisabled">
        Siguiente
    </a>
</div>