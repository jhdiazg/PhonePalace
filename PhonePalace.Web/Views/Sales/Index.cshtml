@model IEnumerable<PhonePalace.Domain.Entities.Sale>
@using PhonePalace.Web.Helpers

@{
    ViewData["Title"] = "Ventas";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning">
        @TempData["Warning"]
    </div>
}
@if (TempData["Info"] != null)
{
    <div class="alert alert-info">
        @TempData["Info"]
    </div>
}

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h5 class="mb-0">Filtros</h5>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Fecha Inicio</label>
                <input type="date" name="startDate" value="@ViewData["StartDate"]" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Fecha Fin</label>
                <input type="date" name="endDate" value="@ViewData["EndDate"]" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Cliente</label>
                <input type="text" name="clientName" value="@ViewData["ClientName"]" class="form-control" placeholder="Buscar por nombre..." />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
            <div class="col-md-1">
                <a href="@Url.Action("Index")" class="btn btn-secondary w-100">Limpiar</a>
            </div>
        </form>
    </div>
</div>

<p>
    <a asp-action="Create" class="btn btn-primary">Registrar Nueva Venta</a>
</p>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Fecha de Venta</th>
                        <th>Canal de Venta</th>
                        <th>Monto Total</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.SaleID</td>
                            <td>@item.Client.DisplayName</td>
                            <td>@item.SaleDate.ToString("dd/MM/yyyy")</td>
                            <td>@(item.Invoice != null ? EnumHelper.GetDisplayName(item.Invoice.SaleChannel) : "")</td>
                            <td>@String.Format("{0:C}", item.Invoice?.Total)</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.SaleID" class="btn btn-sm btn-info">Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.SaleID" class="btn btn-sm btn-danger">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Any())
        {
            <div class="mt-3">
                <strong>Total de Ventas Consultadas: @String.Format("{0:C}", ViewData["Total"])</strong>
            </div>
        }
    </div>
</div>