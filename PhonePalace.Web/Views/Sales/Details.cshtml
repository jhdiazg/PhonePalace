@model PhonePalace.Domain.Entities.Sale
@using PhonePalace.Web.Helpers

@{
    ViewData["Title"] = "Detalles de Venta";
}

<h1>@ViewData["Title"]</h1>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h4 class="mb-0">Información de la Venta</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">
                ID de Venta
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.SaleID)
            </dd>
            <dt class="col-sm-2">
                Fecha de Venta
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.SaleDate)
            </dd>
            <dt class="col-sm-2">
                Cliente
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Client.DisplayName)
            </dd>
            <dt class="col-sm-2">
                Canal de Venta
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Invoice.SaleChannel)
            </dd>
            <dt class="col-sm-2">
                Monto Total
            </dt>
            <dd class="col-sm-10">
                @String.Format("{0:C}", Model.TotalAmount)
            </dd>
        </dl>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h4 class="mb-0">Productos Vendidos</h4>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Precio Unitario</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Details)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.Product.Name)</td>
                            <td>@Html.DisplayFor(modelItem => item.Quantity)</td>
                            <td>@String.Format("{0:C}", item.UnitPrice)</td>
                            <td>@String.Format("{0:C}", item.Quantity * item.UnitPrice)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.Invoice?.Payments != null && Model.Invoice.Payments.Any())
{
    <div class="card shadow-sm">
        <div class="card-header">
            <h4 class="mb-0">Formas de Pago</h4>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Método de Pago</th>
                            <th>Monto</th>
                            <th>Referencia</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model.Invoice.Payments)
                        {
                            <tr>
                                <td>@EnumHelper.GetDisplayName(payment.PaymentMethod)</td>
                                <td>@String.Format("{0:C}", payment.Amount)</td>
                                <td>@(payment.ReferenceNumber ?? "N/A")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Volver a la Lista</a>
</div>
