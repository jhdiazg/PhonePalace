@model PhonePalace.Domain.Entities.Sale
@using PhonePalace.Web.Helpers
@using PhonePalace.Domain.Entities
@using PhonePalace.Infrastructure.Configuration

@{
    ViewData["Title"] = "Detalles de Venta";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm mb-4 h-100">
            <div class="card-header">
                <h4 class="mb-0">Información de la Venta</h4>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">
                        Fecha de Venta
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.SaleDate)
                    </dd>
                    <dt class="col-sm-4">
                        No. Factura (Interno)
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.Invoice.InvoiceID)
                    </dd>
                    <dt class="col-sm-4">
                        Cliente
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.Client.DisplayName)
                    </dd>
                    <dt class="col-sm-4">
                        Canal de Venta
                    </dt>
                    <dd class="col-sm-8">
                        @Html.DisplayFor(model => model.Invoice.SaleChannel)
                    </dd>
                    <dt class="col-sm-4">
                        Monto Total
                    </dt>
                    <dd class="col-sm-8">
                        @String.Format("{0:C}", Model.TotalAmount)
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <!-- BLOQUE DE FACTURACIÓN ELECTRÓNICA -->
        <div class="card shadow-sm mb-4 border-info h-100">
            <div class="card-header bg-info text-white">
                <h5 class="mb-0"><i class="bi bi-receipt"></i> Facturación Electrónica</h5>
            </div>
            <div class="card-body">
                @if (ViewBag.CompanySettings != null)
                {
                    var settings = (CompanySettings)ViewBag.CompanySettings;
                    <div class="alert alert-light border mb-3 p-2" style="font-size: 0.85rem;">
                        <div class="row align-items-center">
                            <!-- Columna de Resolución Activa -->
                            <div class="col-md-7">
                                <strong class="d-block text-muted"><i class="bi bi-info-circle"></i> Resolución Activa:</strong>
                                <span class="d-block"><strong>Num:</strong> @settings.DianResolutionNumber</span>
                                <span class="d-block"><strong>Prefijo:</strong> @settings.DianResolutionPrefix | <strong>Rango:</strong> @settings.DianResolutionStartNumber - @settings.DianResolutionEndNumber</span>
                                <span class="d-block"><strong>Vigencia:</strong> @settings.DianResolutionStartDate hasta @settings.DianResolutionEndDate</span>
                            </div>

                            <!-- Columna de Siguiente Consecutivo (solo si no se ha emitido) -->
                            @if (ViewBag.ElectronicInvoice == null && ViewBag.NextElectronicInvoiceNumber != null)
                            {
                                <div class="col-md-5 text-center border-start">
                                    <small class="text-muted d-block">Siguiente Consecutivo:</small>
                                    <strong class="fs-5 font-monospace text-primary">
                                        @settings.DianResolutionPrefix-@ViewBag.NextElectronicInvoiceNumber
                                    </strong>
                                </div>
                            }
                        </div>
                    </div>
                }
                @if (Model.Invoice.Status == PhonePalace.Domain.Enums.InvoiceStatus.Cancelled)
                {
                    <div class="alert alert-danger mb-0">
                        <div class="d-flex align-items-center">
                            <i class="bi bi-x-circle-fill fs-2 me-3"></i>
                            <div>
                                <h6 class="alert-heading fw-bold mb-1">FACTURA ANULADA</h6>
                                <span class="badge bg-danger">Cancelada</span>
                            </div>
                        </div>
                        <hr />
                        <p class="mb-0 small">Esta venta fue anulada. Se generó una Nota Crédito si correspondía y los movimientos fueron reversados.</p>
                        
                        @* Botón de Reintento de Nota Crédito *@
                        @if (ViewBag.ElectronicInvoice != null && ((ElectronicInvoice)ViewBag.ElectronicInvoice).Status == "Accepted")
                        {
                            <hr />
                            <p class="small text-muted mb-1">¿La Nota Crédito no llegó a la DIAN?</p>
                            <form asp-action="RetryCreditNote" asp-route-id="@Model.SaleID" method="post">
                                @Html.AntiForgeryToken()
                                <div class="input-group input-group-sm">
                                    <input type="text" name="reason" class="form-control" placeholder="Motivo (Opcional)" value="Anulación de venta">
                                    <button type="submit" class="btn btn-outline-danger" title="Reintentar envío a DIAN"><i class="bi bi-cloud-upload"></i> Reenviar NC</button>
                                </div>
                            </form>
                        }
                    </div>
                }
                else if (ViewBag.ElectronicInvoice != null)
                {
                    var electronic = (ElectronicInvoice)ViewBag.ElectronicInvoice;

                    if (electronic.Status == "Accepted")
                    {
                        <div class="alert alert-success mb-0">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-check-circle-fill fs-2 me-3"></i>
                                <div>
                                    <h6 class="alert-heading fw-bold mb-1">@electronic.DianNumber</h6>
                                    <span class="badge bg-success">Aceptada DIAN</span>
                                </div>
                            </div>
                            <hr />
                            <p class="mb-1" style="font-size: 0.8rem; word-break: break-all;">
                                <strong>CUFE:</strong> @electronic.CUFE
                            </p>
                            @if (!string.IsNullOrEmpty(electronic.QRCodeUrl))
                            {
                                <div class="mt-2 text-center">
                                    <a href="@electronic.QRCodeUrl" target="_blank" class="btn btn-outline-success btn-sm w-100">
                                        <i class="bi bi-qr-code"></i> Ver en DIAN
                                    </a>
                                </div>
                            }
                        </div>
                    }
                    else if (electronic.Status == "Pending")
                    {
                        <div class="alert alert-warning mb-0">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-hourglass-split fs-2 me-3"></i>
                                <div>
                                    <h6 class="alert-heading fw-bold mb-1">Emisión Pendiente</h6>
                                    <span class="badge bg-warning text-dark">Pendiente</span>
                                </div>
                            </div>
                            <hr />
                            <p class="mb-1" style="font-size: 0.9rem;">
                                La factura se envió a la DIAN, pero no se ha recibido una confirmación final.
                                Use el botón de sincronizar para consultar el estado actual.
                            </p>
                            <form asp-action="SincronizarFacturaElectronica" asp-route-electronicInvoiceId="@electronic.ElectronicInvoiceID" method="post" class="mt-3">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-warning btn-sm w-100">
                                    <i class="bi bi-arrow-repeat me-2"></i> Sincronizar Estado
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger mb-0">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-exclamation-triangle-fill fs-2 me-3"></i>
                                <div>
                                    <h6 class="alert-heading fw-bold mb-1">Rechazada / Error</h6>
                                    <span class="badge bg-danger">@electronic.Status</span>
                                </div>
                            </div>
                            <hr />
                            <p class="mb-1" style="font-size: 0.9rem;">
                                <strong>Motivo:</strong> @(electronic.ErrorMessage ?? "Sin detalles del error.")
                            </p>

                            <form asp-action="EmitirFacturaElectronica" asp-route-id="@Model.SaleID" method="post" class="mt-3">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm w-100" onclick="return confirm('¿Está seguro de reintentar la emisión?');">
                                    <i class="bi bi-arrow-repeat me-2"></i> Reintentar Emisión
                                </button>
                            </form>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center">
                        <span class="badge bg-secondary mb-3 p-2">Estado: Remisión / Local</span>
                        <p class="text-muted small mb-3">
                            Esta venta aún no ha sido transmitida a la DIAN.
                        </p>

                        @if (string.IsNullOrEmpty(Model.Client.Email))
                        {
                            <div class="alert alert-warning text-start small mb-2">
                                <i class="bi bi-exclamation-triangle-fill"></i> El cliente no tiene email registrado.
                            </div>
                            <a asp-controller="Clients" asp-action="Edit" asp-route-id="@Model.ClientID" class="btn btn-outline-warning w-100">
                                <i class="bi bi-person-lines-fill"></i> Editar Cliente
                            </a>
                        }
                        else
                        {
                            <form asp-action="EmitirFacturaElectronica" asp-route-id="@Model.SaleID" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-primary w-100" onclick="return confirm('¿Está seguro de emitir la Factura Electrónica para esta venta?');">
                                    <i class="bi bi-cloud-arrow-up-fill me-2"></i> Emitir Electrónica
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@if (ViewBag.CreditInfo != null)
{
    var credit = (PhonePalace.Domain.Entities.AccountReceivable)ViewBag.CreditInfo;
    <div class="card shadow-sm mb-4 border-info">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0"><i class="bi bi-credit-card-2-front me-2"></i>Información del Crédito</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <strong>Estado:</strong><br>
                    @if (credit.IsPaid)
                    {
                        <span class="badge bg-success">Pagado Totalmente</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pendiente</span>
                    }
                </div>
                <div class="col-md-3">
                    <strong>Saldo Pendiente:</strong><br>
                    <span class="text-danger fw-bold fs-5">@credit.Balance.ToString("C")</span>
                </div>
                <div class="col-md-3">
                    <strong>Monto Original:</strong><br>
                    <span>@credit.TotalAmount.ToString("C")</span>
                </div>
                <div class="col-md-3 text-end">
                    <a asp-controller="AccountReceivables" asp-action="Details" asp-route-id="@credit.AccountReceivableID" class="btn btn-sm btn-outline-primary">
                        Ver Abonos / Detalles
                    </a>
                </div>
            </div>
        </div>
    </div>
}

<div class="card shadow-sm">
    <div class="card-header">
        <h4 class="mb-0">Productos Vendidos</h4>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Precio Unitario</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Details)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.Product.Name)</td>
                            <td>@Html.DisplayFor(modelItem => item.Quantity)</td>
                            <td>@String.Format("{0:C}", item.UnitPrice)</td>
                            <td>@String.Format("{0:C}", item.Quantity * item.UnitPrice)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (Model.Invoice?.Payments != null && Model.Invoice.Payments.Any())
{
    <div class="card shadow-sm">
        <div class="card-header">
            <h4 class="mb-0">Formas de Pago</h4>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead>
                        <tr>
                            <th>Método de Pago</th>
                            <th>Monto</th>
                            <th>Referencia</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model.Invoice.Payments)
                        {
                            <tr>
                                <td>@EnumHelper.GetDisplayName(payment.PaymentMethod)</td>
                                <td>@String.Format("{0:C}", payment.Amount)</td>
                                <td>@(payment.ReferenceNumber ?? "N/A")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<div class="mt-4">
    <a asp-action="GenerateInvoicePdf" asp-route-id="@Model.SaleID" class="btn btn-primary me-2" target="_blank">
        <i class="bi bi-file-pdf"></i> Descargar Remisión PDF
    </a>
    <a asp-controller="Returns" asp-action="Create" asp-route-saleId="@Model.SaleID" class="btn btn-warning me-2">
        <i class="bi bi-arrow-counterclockwise"></i> Realizar Devolución
    </a>
    @{ var currentCashDate = ViewData["CurrentCashDate"] as DateTime?; }
    @if (currentCashDate.HasValue && Model.SaleDate.Date == currentCashDate.Value.Date)
    {
        <button type="button" class="btn btn-danger me-2" data-bs-toggle="modal" data-bs-target="#deleteModal">
            <i class="bi bi-trash"></i> Anular Venta
        </button>
    }
    <a asp-action="Index" class="btn btn-secondary">Volver a la Lista</a>
</div>

<!-- Modal de Confirmación de Anulación -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="deleteModalLabel">Confirmar Anulación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Delete" asp-route-id="@Model.SaleID" method="post">
                <div class="modal-body">
                    <p>¿Está seguro que desea anular esta venta?</p>
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Advertencia:</strong> Esta acción devolverá los productos al inventario, reversará el dinero de caja/bancos y anulará la deuda si existe.
                    </div>
                    @{
                        var eInvoiceForModal = ViewBag.ElectronicInvoice as ElectronicInvoice;
                        bool isElectronic = eInvoiceForModal != null && eInvoiceForModal.Status == "Accepted";
                    }
                    @if (isElectronic)
                    {
                        <div class="mb-3">
                            <label for="cancellationReason" class="form-label fw-bold">Motivo de Anulación (DIAN):</label>
                            <textarea name="cancellationReason" id="cancellationReason" class="form-control" rows="2" placeholder="Ej: Error en digitación, Devolución total..." required></textarea>
                            <div class="invalid-feedback">El motivo es obligatorio para anular una factura electrónica.</div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Confirmar Anulación</button>
                </div>
            </form>
        </div>
    </div>
</div>
