@model PhonePalace.Web.ViewModels.SaleCreateViewModel
@using PhonePalace.Domain.Enums
@using PhonePalace.Domain.Entities
@using System.Text.Json
@using PhonePalace.Web.Helpers

@{
    ViewData["Title"] = "Registrar Nueva Venta";
}

@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form asp-action="Create" id="saleForm" novalidate>
    <div asp-validation-summary="All" class="text-danger"></div>
    <div id="hidden-inputs-container" style="display:none;"></div>

    <div class="row">
        <!-- Columna principal de contenido -->
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <h4 class="mb-0">Información de la Venta</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label asp-for="ClientID" class="control-label"></label>
                            <select asp-for="ClientID" class="form-control" asp-items="Model.Clients">
                                <option value="">-- Seleccione un Cliente --</option>
                            </select>
                            <span asp-validation-for="ClientID" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 form-group">
                            <label asp-for="SaleChannel" class="control-label"></label>
                            <select asp-for="SaleChannel" class="form-control" asp-items="Model.SaleChannels">
                                <option value="">-- Seleccione un Canal de Venta --</option>
                            </select>
                            <span asp-validation-for="SaleChannel" class="text-danger"></span>
                        </div>
                        <div class="col-md-4 form-group">
                            <label for="price-list-select" class="control-label">Lista de Precios</label>
                            <select id="price-list-select" class="form-control" asp-items="@(new SelectList(ViewBag.PriceListTypes, "Value", "Text"))">
                                <option value="">-- Manual / Predeterminado --</option>
                            </select>
                        </div>
                        <div class="col-md-4 form-group mt-3">
                            <label asp-for="SaleDate" class="control-label"></label>
                            <input asp-for="SaleDate" class="form-control" readonly type="date" />
                            <span asp-validation-for="SaleDate" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-header">
                    <h4 class="mb-0">Productos</h4>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 form-group">
                            <label for="category-select">Categoría</label>
                            <select id="category-select" class="form-control" asp-items="ViewBag.Categories">
                                <option value="">-- Todas las Categorías --</option>
                            </select>
                        </div>
                        <div class="col-md-8 form-group">
                            <label for="product-select">Producto (Nombre o SKU)</label>
                            <select id="product-select" name="Products" class="form-control">
                                <option value="">-- Seleccione un Producto --</option>
                                @foreach (var product in (IEnumerable<Product>)ViewBag.AllProducts)
                                {
                                    <option value="@product.ProductID" data-category-id="@product.CategoryID">@product.Name (@product.SKU)</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="row align-items-end mt-3">
                        <div class="col-md-2 form-group">
                            <label for="price-input">Precio</label>
                            <input type="number" id="price-input" class="form-control" min="0" step="0.01">
                        </div>
                        <div class="col-md-2 form-group">
                            <label for="quantity-input">Cantidad</label>
                            <input type="number" id="quantity-input" class="form-control" value="1" min="1">
                        </div>
                        <div class="col-md-2 form-group" id="imei-group" style="display:none;">
                            <label for="imei-input">IMEI <small class="text-muted">(Opcional)</small></label>
                            <input type="text" id="imei-input" class="form-control">
                        </div>
                        <div class="col-md-2 form-group" id="serial-group" style="display:none;">
                            <label for="serial-input">Serial <small class="text-muted">(Opcional)</small></label>
                            <input type="text" id="serial-input" class="form-control">
                        </div>
                        <div class="col-md-2 form-group">
                            <button type="button" id="add-product-btn" class="btn btn-info w-100">Agregar</button>
                        </div>
                    </div>
                    <div class="table-responsive mt-3">
                        <table class="table table-bordered table-striped">
                            <thead class="table-light">
                                <tr>
                                    <th>Producto</th>
                                    <th>Cantidad</th>
                                    <th>Precio Unit.</th>
                                    <th>Identificador</th>
                                    <th>Subtotal</th>
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody id="product-details-body">
                                <!-- Filas de productos agregados dinámicamente -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-header">
                    <h4 class="mb-0">Formas de Pago</h4>
                </div>
                <div class="card-body">
                    <div class="row align-items-end gx-3">
                        <div class="col-md-3 form-group">
                            <label for="payment-method-select">Método de Pago</label>
                            <select id="payment-method-select" name="PaymentMethods" class="form-control" asp-items="Model.PaymentMethods">
                                <option value="">-- Seleccione un Método de Pago --</option>
                            </select>
                        </div>
                        <div class="col-md-3 form-group" id="bank-selection-group" style="display: none;">
                            <label for="bank-select">Cuenta Destino</label>
                            <select id="bank-select" class="form-control" asp-items="ViewBag.Banks">
                                <option value="">-- Seleccione Banco --</option>
                            </select>
                        </div>
                        <div class="col-md-2 form-group">
                            <label for="payment-amount-input">Monto</label>
                            <input type="number" id="payment-amount-input" class="form-control" min="0" step="0.01">
                        </div>
                        <div class="col-md-3 form-group">
                            <label for="payment-reference-input">Referencia</label>
                            <input type="text" id="payment-reference-input" class="form-control" placeholder="(Opcional)">
                        </div>
                        <div class="col-md-2 form-group mt-3 mt-md-0">
                            <button type="button" id="add-payment-btn" class="btn btn-info w-100">Agregar</button>
                        </div>
                    </div>
                    <div class="table-responsive mt-3">
                        <table class="table table-bordered table-striped">
                            <thead class="table-light">
                                <tr>
                                    <th>Método</th>
                                    <th>Monto</th>
                                    <th>Referencia</th>
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody id="payment-details-body">
                                <!-- Filas de pagos agregados dinámicamente -->
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">Completar Venta</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>

        </div>

        <!-- Columna lateral para el resumen -->
        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top: 20px;">
                <div class="card-header">
                    <h4 class="mb-0">Resumen de la Venta</h4>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            Subtotal
                            <span id="subtotal-display" class="fw-bold">$0.00</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            IVA (@(((decimal)(ViewBag.TaxRate ?? 0.19m) * 100).ToString("F0"))%)
                            <span id="tax-display" class="fw-bold">$0.00</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center fs-5 fw-bold">
                            Total Factura
                            <span id="total-display" class="text-primary">$0.00</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center text-success">
                            Total Pagado
                            <span id="paid-display" class="fw-bold">$0.00</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center fs-5 fw-bold">
                            Balance
                            <span id="balance-display" class="text-danger">$0.00</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function () {
            // Data from the server
            function roundToNearestThousand(num) {
                if (isNaN(num)) return 0;
                return Math.round(num / 1000) * 1000;
            }

            const taxRate = @Json.Serialize(ViewBag.TaxRate ?? 0.19m);
            const defaultCardBankId = @Json.Serialize(ViewBag.DefaultCardBankId);
            const surchargePercentage = @Json.Serialize(ViewBag.CardSurchargePercentage ?? 0);

            // State
            let products = [];
            let payments = [];

            // Inicializa cliente si viene del modelo
            var initialClientId = '@Model.ClientID';
            if (initialClientId && initialClientId !== '0') {
                $("select[name='ClientID']").val(initialClientId).trigger('change');
            }
            // Establece el canal de venta automáticamente si viene de conversión
            var initialSaleChannel = '@Model.SaleChannel';
            if (initialSaleChannel && initialSaleChannel === 'Quotations') {
                $("select[name='SaleChannel']").val('Quotations').trigger('change');
            }

            // Diccionario de productos para inicialización rápida
            var allProductsDict = @Html.Raw(Json.Serialize(((IEnumerable<Product>)ViewBag.AllProducts).ToDictionary(
                p => p.ProductID.ToString(),
                p => new { 
                    id = p.ProductID, 
                    name = p.Name, 
                    price = p.Price, 
                    cost = p.Cost, 
                    type = (p is PhonePalace.Domain.Entities.CellPhone ? "CellPhone" : "Accessory") 
                }
            )));

            // Inicializa productos si vienen del modelo
            var initialDetails = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Details ?? new List<PhonePalace.Web.ViewModels.SaleDetailViewModel>()));
            if (initialDetails && initialDetails.length > 0) {
                initialDetails.forEach(function (d) {
                    var prod = allProductsDict[String(d.ProductID)];
                    if (prod) {
                        products.push({
                            id: prod.id,
                            name: prod.name,
                            price: d.UnitPrice || prod.price,
                            quantity: d.Quantity,
                            imei: d.IMEI,
                            serial: d.Serial
                        });
                    }
                });
                renderProducts();
                updateTotals();
            }

            // Diccionario de métodos de pago para inicialización rápida
            var paymentMethodEnum = {
                @foreach(var val in Enum.GetValues(typeof(PaymentMethod)))
                {
                    <text>'@val.ToString()': '@EnumHelper.GetDisplayName((Enum)val)',</text>
                }
            };

            // Inicializa pagos si vienen del modelo (en caso de error de validación)
            var initialPayments = @Html.Raw(Json.Serialize(Model.Payments ?? new List<PhonePalace.Web.ViewModels.PaymentViewModel>()));
            if (initialPayments && initialPayments.length > 0) {
                initialPayments.forEach(function(p) {
                    payments.push({
                        method: p.PaymentMethod,
                        methodText: paymentMethodEnum[p.PaymentMethod] || p.PaymentMethod,
                        amount: p.Amount,
                        reference: p.ReferenceNumber,
                        surcharge: 0 // Asumimos 0 si viene del modelo recargado por error, o recalcular si es necesario
                    });
                });
                renderPayments(); 
                // updateTotals() es llamado dentro de renderPayments()
            }

            // Initialize Select2
            $('#ClientID').select2({ placeholder: "-- Seleccione un Cliente --", width: '100%' });
            $('#SaleChannel').select2({ placeholder: "-- Seleccione un Canal de Venta --", width: '100%' });
            $('#category-select').select2({ placeholder: "-- Todas las Categorías --", width: '100%', allowClear: true });
            $('#product-select').select2({ placeholder: "-- Seleccione un Producto --", width: '100%' });
            $('#payment-method-select').select2({ placeholder: "-- Seleccione un Método de Pago --", width: '100%' });
            $('#price-list-select').select2({ placeholder: "-- Manual / Predeterminado --", width: '100%', allowClear: true });

            // --- PAYMENT METHOD LOGIC ---
            const bankPaymentMethods = ['Card', 'Transfer', 'Nequi', 'Daviplata', 'DebitCard', 'CreditCard'];

            $('#payment-method-select').on('change', function() {
                const selectedMethod = $(this).val();
                if (bankPaymentMethods.includes(selectedMethod)) {
                    $('#bank-selection-group').show();
                    
                    // Auto-seleccionar banco por defecto si es Tarjeta
                    if ((selectedMethod === 'Card' || selectedMethod === 'DebitCard' || selectedMethod === 'CreditCard') && defaultCardBankId) {
                        $('#bank-select').val(defaultCardBankId).trigger('change');
                    }
                } else {
                    $('#bank-selection-group').hide();
                    $('#bank-select').val(null).trigger('change'); // Limpiar selección al ocultar
                }
            });

            // --- CATEGORY FILTER LOGIC ---
            const allProductOptionsHTML = $('#product-select').html(); // Save initial options as a string

            $('#category-select').on('change', function() {
                const selectedCategoryId = $(this).val();
                const productSelect = $('#product-select');
                
                // Reset product selection before filtering
                productSelect.val('').trigger('change');

                // Restore all options from the saved string
                productSelect.html(allProductOptionsHTML);

                if (selectedCategoryId) {
                    // Filter and remove non-matching options from the DOM
                    productSelect.find('option').filter(function() {
                        // Keep the placeholder and the matching options
                        return $(this).val() !== '' && $(this).data('category-id') != selectedCategoryId;
                    }).remove();
                }
                
                // Re-initialize select2 to reflect the new set of options
                productSelect.select2({ placeholder: "-- Seleccione un Producto --", width: '100%' });
            });

            $('#price-list-select').on('change', function() {
                // Recalculate price if a product is already selected
                $('#product-select').trigger('change');
            });

            // --- DYNAMIC FIELDS LOGIC ---
            $('#product-select').on('change', function() {
                const productId = $(this).val();
                const imeiGroup = $('#imei-group');
                const serialGroup = $('#serial-group');
                const priceInput = $('#price-input');
                
                imeiGroup.hide();
                serialGroup.hide();

                if (productId && allProductsDict[productId]) {
                    const productInfo = allProductsDict[productId];
                    const type = productInfo.type;
                    if (type === 'CellPhone') imeiGroup.show();
                    else imeiGroup.hide(); // Accesorios u otros usan Serial si se desea, o ajustar lógica
                    
                    if (type !== 'CellPhone') serialGroup.show();

                    // --- Price Calculation Logic ---
                    const priceListPercentage = $('#price-list-select').val();
                    if (priceListPercentage && productInfo.cost > 0 && !isNaN(parseFloat(priceListPercentage))) {
                        const percentage = parseFloat(priceListPercentage);
                        const rawPrice = productInfo.cost * (1 + percentage / 100);
                        priceInput.val(roundToNearestThousand(rawPrice));
                    } else {
                        // Set default price if no list is selected
                        priceInput.val(productInfo.price);
                    }
                }
            });

            $('#price-input').on('blur', function() {
                const price = parseFloat($(this).val());
                const productId = $('#product-select').val();

                if (!productId || !allProductsDict[productId] || isNaN(price)) {
                    return; // No product selected or invalid price
                }

                const productInfo = allProductsDict[productId];
                if (price < productInfo.cost) {
                    alert(`El precio de venta no puede ser inferior al costo del producto ($${formatCurrency(productInfo.cost)}). Se restaurará el precio calculado.`);
                    
                    // Restore the calculated price
                    const priceListPercentage = $('#price-list-select').val();
                    let restoredPrice;
                    if (priceListPercentage && productInfo.cost > 0 && !isNaN(parseFloat(priceListPercentage))) {
                        const percentage = parseFloat(priceListPercentage);
                        const rawPrice = productInfo.cost * (1 + percentage / 100);
                        restoredPrice = roundToNearestThousand(rawPrice);
                    } else {
                        restoredPrice = productInfo.price;
                    }
                    $(this).val(restoredPrice);
                }
            });

            // --- PRODUCT LOGIC ---
            $('#add-product-btn').on('click', function () {
                const productId = $('#product-select').val();
                const price = parseFloat($('#price-input').val());
                const quantity = parseInt($('#quantity-input').val(), 10);
                const imei = $('#imei-input').val();
                const serial = $('#serial-input').val();

                if (!productId || isNaN(price) || quantity <= 0) {
                    alert("Por favor, seleccione un producto, un precio válido y una cantidad.");
                    return;
                }

                // Validación de Precio (Mínimo Costo, Máximo Doble del Costo)
                const productInfo = allProductsDict[productId];
                if (productInfo) {
                    if (price < productInfo.cost) {
                        alert(`El precio no puede ser menor al costo ($${formatCurrency(productInfo.cost)}).`);
                        return;
                    }
                    if (price > productInfo.cost * 3) {
                        alert(`El precio no puede ser mayor al triple del costo ($${formatCurrency(productInfo.cost * 3)}).`);
                        return;
                    }
                }

                fetch(`/api/products/${productId}`)
                    .then(response => {
                        if (!response.ok) throw new Error('Producto no encontrado o error en el servidor.');
                        return response.json();
                    })
                    .then(productData => {
                        const existingProduct = products.find(p => p.id === productData.id);
                        if (existingProduct) {
                            existingProduct.quantity += quantity;
                        } else {
                            products.push({
                                id: productData.id,
                                name: productData.name,
                                quantity: quantity,
                                price: price, // Usar el precio ingresado por el usuario
                                imei: imei,
                                serial: serial
                            });
                        }
                        renderProducts();
                        updateTotals();
                        $('#product-select').val('').trigger('change');
                        $('#quantity-input').val(1);
                        $('#price-input').val('');
                        $('#imei-input').val('');
                        $('#serial-input').val('');
                    })
                    .catch(error => {
                        console.error("Error al obtener datos del producto:", error);
                        alert("No se pudo obtener la información del producto. " + error.message);
                    });
            });

            function renderProducts() {
                const tbody = $('#product-details-body');
                tbody.empty();
                products.forEach((p, index) => {
                    const subtotal = p.quantity * p.price;
                    const identifier = p.imei ? `IMEI: ${p.imei}` : (p.serial ? `SN: ${p.serial}` : '-');
                    const row = `
                        <tr data-product-id="${p.id}">
                            <td>${p.name}</td>
                            <td>${p.quantity}</td>
                            <td>${formatCurrency(p.price)}</td>
                            <td><small>${identifier}</small></td>
                            <td>${formatCurrency(subtotal)}</td>
                            <td><button type="button" class="btn btn-danger btn-sm remove-product-btn" data-index="${index}">&times;</button></td>
                        </tr>`;
                    tbody.append(row);
                });
            }

            $(document).on('click', '.remove-product-btn', function () {
                const index = $(this).data('index');
                products.splice(index, 1);
                renderProducts();
                updateTotals();
            });

            // --- PAYMENT LOGIC ---
            function renderPayments() {
                const tbody = $('#payment-details-body');
                tbody.empty();
                payments.forEach((p, index) => {
                    const row = `
                        <tr data-payment-index="${index}">
                            <td>${p.methodText}</td>
                            <td>${formatCurrency(p.amount)}</td>
                            <td>${p.reference}</td>
                            <td><button type="button" class="btn btn-danger btn-sm remove-payment-btn" data-index="${index}">&times;</button></td>
                        </tr>`;
                    tbody.append(row);
                });
                updateTotals();
            }

            $('#add-payment-btn').on('click', function() {
                const methodSelect = $('#payment-method-select');
                const amountInput = $('#payment-amount-input');
                const referenceInput = $('#payment-reference-input');

                const method = methodSelect.val();
                const methodText = methodSelect.find('option:selected').text();
                const amount = parseFloat(amountInput.val());
                const reference = referenceInput.val();
                const bankId = $('#bank-select').val();

                if (!method || !amount || amount <= 0) {
                    alert('Por favor, seleccione un método de pago y un monto válido.');
                    return;
                }

                if (bankPaymentMethods.includes(method) && !bankId) {
                    alert('Por favor, seleccione una cuenta de destino para este método de pago.');
                    return;
                }

                let finalAmount = amount;
                let surchargeAmount = 0;

                // Lógica de Recargo para Tarjetas
                if ((method === 'CreditCard' || method === 'DebitCard') && surchargePercentage > 0) {
                    surchargeAmount = amount * (surchargePercentage / 100);
                    finalAmount = amount + surchargeAmount;

                    if (!confirm(`Se aplicará un recargo del ${surchargePercentage}% ($${formatCurrency(surchargeAmount)}) por pago con tarjeta.\n\nTotal a cobrar: $${formatCurrency(finalAmount)}`)) {
                        return;
                    }
                    // Actualizamos el texto para indicar que incluye recargo
                    // methodText += ` (+${surchargePercentage}%)`; 
                }

                payments.push({ method, methodText, amount: finalAmount, reference, bankId: bankPaymentMethods.includes(method) ? bankId : null, surcharge: surchargeAmount });
                renderPayments();

                // Clear inputs
                amountInput.val('');
                referenceInput.val('');
                $('#bank-select').val('');
                methodSelect.val('').trigger('change');
            });

            $(document).on('click', '.remove-payment-btn', function () {
                const index = $(this).data('index');
                payments.splice(index, 1);
                renderPayments();
            });


            // --- TOTALS CALCULATION ---
            function updateTotals() {
                // El precio del producto ya incluye IVA, por lo tanto la suma es el Total
                let productsTotal = products.reduce((acc, p) => acc + (p.quantity * p.price), 0);
                let totalSurcharges = payments.reduce((acc, p) => acc + (p.surcharge || 0), 0);
                let total = productsTotal + totalSurcharges;
                
                let subtotal = total / (1 + taxRate);
                let tax = total - subtotal;
                
                const totalPaid = payments.reduce((acc, p) => acc + (p.amount || 0), 0);
                const balance = total - totalPaid;

                $('#subtotal-display').text(formatCurrency(subtotal));
                $('#tax-display').text(formatCurrency(tax));
                $('#total-display').text(formatCurrency(total));
                $('#paid-display').text(formatCurrency(totalPaid));
                $('#balance-display').text(formatCurrency(balance));

                // Actualizar el campo de monto en la forma de pago con el balance
                if (balance > 0.01) {
                    $('#payment-amount-input').val(balance.toFixed(2));
                } else {
                    $('#payment-amount-input').val('');
                }
            }

            // --- FORM SUBMISSION ---
            $('#saleForm').on('submit', function (e) {
                e.preventDefault();

                const hiddenContainer = $('#hidden-inputs-container');
                hiddenContainer.empty();

                if (products.length === 0) {
                    alert("Debe agregar al menos un producto a la venta.");
                    return;
                }

                products.forEach((p, index) => {
                    hiddenContainer.append(`<input type="hidden" name="Details[${index}].ProductID" value="${p.id}" />`);
                    hiddenContainer.append(`<input type="hidden" name="Details[${index}].Quantity" value="${p.quantity}" />`);
                    hiddenContainer.append(`<input type="hidden" name="Details[${index}].UnitPrice" value="${p.price}" />`);
                    if(p.imei) hiddenContainer.append(`<input type="hidden" name="Details[${index}].IMEI" value="${p.imei}" />`);
                    if(p.serial) hiddenContainer.append(`<input type="hidden" name="Details[${index}].Serial" value="${p.serial}" />`);
                });

                // Create a deep copy for manipulation to avoid altering the UI state on failed submission
                let finalPayments = JSON.parse(JSON.stringify(payments));

                if (finalPayments.length === 0) {
                    alert("Debe agregar al menos un método de pago a la venta.");
                    return;
                }

                // Ajustar dinámicamente el monto del último pago al balance
                let productsTotal = products.reduce((acc, p) => acc + (p.quantity * p.price), 0);
                let totalSurcharges = finalPayments.reduce((acc, p) => acc + (p.surcharge || 0), 0);
                let total = productsTotal + totalSurcharges;

                let totalPaid = finalPayments.reduce((acc, p) => acc + (p.amount || 0), 0);
                let balance = total - totalPaid;

                if (Math.abs(balance) > 0.01 && finalPayments.length > 0) {
                    finalPayments[finalPayments.length - 1].amount += balance;
                }

                // Filter out payments that are now zero or less and re-validate
                finalPayments = finalPayments.filter(p => p.amount > 0.001);
                if (finalPayments.length === 0) {
                    alert("El total de los pagos es cero o negativo después del ajuste. Por favor, revise los montos de pago.");
                    return;
                }

                finalPayments.forEach((p, index) => {
                    hiddenContainer.append(`<input type="hidden" name="Payments[${index}].PaymentMethod" value="${p.method}" />`);
                    hiddenContainer.append(`<input type="hidden" name="Payments[${index}].Amount" value="${p.amount}" />`);
                    hiddenContainer.append(`<input type="hidden" name="Payments[${index}].ReferenceNumber" value="${p.reference || ''}" />`);
                    if (p.bankId) {
                        hiddenContainer.append(`<input type="hidden" name="Payments[${index}].BankID" value="${p.bankId}" />`);
                    }
                });

                this.submit();
            });

            // --- INITIALIZATION ---
            updateTotals();

            // --- HELPERS ---
            function formatCurrency(value) {
                return (value || 0).toLocaleString('es-CO', { style: 'currency', currency: 'COP', minimumFractionDigits: 2 });
            }
        });
    </script>
}