@model PhonePalace.Domain.Entities.Sale

@{
    ViewData["Title"] = "Eliminar Venta";
}

<h1>Eliminar Venta</h1>

<h3>¿Está seguro de que desea anular esta venta?</h3>
<div class="card shadow-sm">
    <div class="card-header">
        <h4 class="mb-0">Información de la Venta</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">
                ID de Venta
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.SaleID)
            </dd>
            <dt class="col-sm-2">
                Cliente
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Client.DisplayName)
            </dd>
            <dt class="col-sm-2">
                Fecha de Venta
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.SaleDate)
            </dd>
            <dt class="col-sm-2">
                Canal de Venta
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.Invoice.SaleChannel)
            </dd>
            <dt class="col-sm-2">
                Monto Total
            </dt>
            <dd class="col-sm-10">
                @String.Format("{0:C}", Model.TotalAmount)
            </dd>
        </dl>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="SaleID" />
            <input type="submit" value="Anular Venta" class="btn btn-danger" /> |
            <a asp-action="Index" class="btn btn-secondary">Volver a la Lista</a>
        </form>
    </div>
</div>