@using PhonePalace.Domain.Enums
@model PhonePalace.Web.ViewModels.CellPhoneViewModel

@{
    ViewData["Title"] = "Editar Celular";
}

<h1>@ViewData["Title"]</h1>

<h4>@Model.Name</h4>
<hr />
<div class="row">
    <!-- Columna del Formulario -->
    <div class="col-md-8">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ProductID" />

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">Nombre</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="SKU" class="form-label">SKU</label>
                        <input asp-for="SKU" class="form-control" />
                        <span asp-validation-for="SKU" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Descripción</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-3">
                    <div class="mb-3">
                        <label for="BrandID" class="form-label">Marca</label>
                        <select id="BrandID" name="BrandID" class="form-select" asp-items="ViewBag.BrandID"><option value="">-- Seleccione una Marca --</option></select>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="ModelID" class="form-label">Modelo</label>
                        <select asp-for="ModelID" class="form-select" asp-items="ViewBag.ModelID"></select>
                        <span asp-validation-for="ModelID" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="CategoryID" class="form-label">Categoría</label>
                        <select asp-for="CategoryID" class="form-select" asp-items="ViewBag.CategoryID"></select>
                        <span asp-validation-for="CategoryID" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="Price" class="form-label">Precio</label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="mb-3">
                        <label asp-for="Cost" class="form-label">Costo</label>
                        <input asp-for="Cost" class="form-control" />
                        <span asp-validation-for="Cost" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="Color" class="form-label">Color</label>
                        <input asp-for="Color" class="form-control" />
                        <span asp-validation-for="Color" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="ProductCondition" class="form-label"></label>
                        <select asp-for="ProductCondition" class="form-select" asp-items="@(new SelectList(Enum.GetValues(typeof(ProductCondition))))"><option value="">-- Seleccione una Condición --</option></select>
                        <span asp-validation-for="ProductCondition" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="StorageGB" class="form-label">Almacenamiento (GB)</label>
                        <select asp-for="StorageGB" class="form-select" asp-items="Html.GetEnumSelectList<StorageGB>()"><option value="">-- Seleccione una Opción --</option></select>
                        <span asp-validation-for="StorageGB" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="mb-3">
                        <label asp-for="RamGB" class="form-label">RAM (GB)</label>
                        <select asp-for="RamGB" class="form-select" asp-items="Html.GetEnumSelectList<RamGB>()"><option value="">-- Seleccione una Opción --</option></select>
                        <span asp-validation-for="RamGB" class="text-danger"></span>
                    </div>
                </div>
            </div>
            
            <div class="mb-3">
                <label asp-for="NewImageFile" class="form-label">Añadir Nueva Imagen</label>
                <input asp-for="NewImageFile" class="form-control" type="file" accept="image/*" />
                <span asp-validation-for="NewImageFile" class="text-danger"></span>
            </div>

            <div class="form-check form-switch mb-3">
                <input class="form-check-input" asp-for="IsActive" />
                <label class="form-check-label" asp-for="IsActive">@Html.DisplayNameFor(model => model.IsActive)</label>
            </div>



            <div class="mb-3">
                <input type="submit" value="Guardar Cambios" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>

    <!-- Columna de la Galería de Imágenes -->
    <div class="col-md-4" id="image-gallery-container">
        <h4>Imágenes Actuales</h4>
        <hr />
        @{
            ViewData["ProductID"] = Model.ProductID;
        }
        @await Html.PartialAsync("_ImageGalleryPartial", Model.Images)
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function () {
            $('#BrandID').change(function () {
                var brandId = $(this).val();
                var modelSelect = $('#ModelID');
                modelSelect.empty();
                modelSelect.append($('<option/>', { value: '', text: '-- Seleccione un Modelo --' }));
                if (brandId) {
                    $.getJSON('@Url.Action("GetModelsByBrand")?brandId=' + brandId, function (models) {
                        $.each(models, function (index, model) {
                            modelSelect.append($('<option/>', { value: model.value, text: model.text }));
                        });
                    });
                }
            });
        });
    </script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const galleryContainer = document.getElementById('image-gallery-container');

            galleryContainer.addEventListener('submit', function (event) {
                if (event.target.classList.contains('image-action-form')) {
                    event.preventDefault();
                    const form = event.target;
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                    galleryContainer.style.opacity = '0.5';

                    fetch(form.action, {
                        method: form.method,
                        body: new FormData(form),
                        headers: { 'RequestVerificationToken': token }
                    })
                    .then(response => response.text())
                    .then(html => {
                        galleryContainer.innerHTML = html;
                        galleryContainer.style.opacity = '1';
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert('Ocurrió un error al procesar la solicitud.');
                        galleryContainer.style.opacity = '1';
                    });
                }
            });
        });
    </script>
}