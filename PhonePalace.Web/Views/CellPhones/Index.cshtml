@model PaginatedList<PhonePalace.Domain.Entities.CellPhone>
@using PhonePalace.Web.Helpers

@{
    ViewData["Title"] = "Celulares";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Registrar Nuevo Celular</a>
</p>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Nombre</th>
                        <th>Imagen</th>
                        <th>Marca</th>
                        <th>Modelo</th>
                        <th>Precio</th>
                        <th>Costo</th>
                        <th>SKU</th>
                        <th>Activo</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="@(item.IsActive ? "" : "text-danger")">@Html.DisplayFor(modelItem => item.Name)</td>
                            <td>
                                <img src="@ImageHelper.GetImageUrl(item.Images)" alt="Imagen de @item.Name" class="product-image-thumbnail" />
                            </td>
                            <td class="@(item.IsActive ? "" : "text-danger")">@Html.DisplayFor(modelItem => item.Model.Brand.Name)</td>
                            <td class="@(item.IsActive ? "" : "text-danger")">@Html.DisplayFor(modelItem => item.Model.Name)</td>
                            <td class="@(item.IsActive ? "" : "text-danger")">@item.Price.ToString("C")</td>
                            <td class="@(item.IsActive ? "" : "text-danger")">@item.Cost.ToString("C")</td>
                            <td class="@(item.IsActive ? "" : "text-danger")">@Html.DisplayFor(modelItem => item.SKU)</td>
                            <td class="@(item.IsActive ? "" : "text-danger")">
                                @Html.DisplayFor(modelItem => item.IsActive)
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-secondary">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-info">Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-danger">Borrar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-center align-items-center mt-3">
    @{
        var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
        var nextDisabled = !Model.HasNextPage ? "disabled" : "";
    }
    <a asp-action="Index"
       asp-route-pageNumber="@(Model.PageIndex - 1)"
       class="btn btn-outline-secondary @prevDisabled">
        Anterior
    </a>
    <span class="mx-3">Página @Model.PageIndex de @Model.TotalPages</span>
    <a asp-action="Index"
       asp-route-pageNumber="@(Model.PageIndex + 1)"
       class="btn btn-outline-secondary @nextDisabled">
        Siguiente
    </a>
</div>