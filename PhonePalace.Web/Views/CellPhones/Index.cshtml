
 @model IEnumerable<PhonePalace.Domain.Entities.CellPhone>
@using PhonePalace.Web.Helpers

@{
    ViewData["Title"] = "Celulares";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Registrar Nuevo Celular</a>
</p>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Name)</th>
                        <th>Imagen</th>
                        <th>Marca</th>
                        <th>Modelo</th>
                        <th>@Html.DisplayNameFor(model => model.Price)</th>
                        <th>@Html.DisplayNameFor(model => model.Cost)</th>
                        <th>@Html.DisplayNameFor(model => model.SKU)</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.Name)</td>
                            <td>
                                <img src="@ImageHelper.GetImageUrl(item.Images)" alt="Imagen de @item.Name" class="product-image-thumbnail" />
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.Model.Brand.Name)</td>
                            <td>@Html.DisplayFor(modelItem => item.Model.Name)</td>
                            <td>@Html.DisplayFor(modelItem => item.Price)</td>
                            <td>@Html.DisplayFor(modelItem => item.Cost)</td>
                            <td>@Html.DisplayFor(modelItem => item.SKU)</td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-secondary">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-info">Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-danger">Borrar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>