@model PhonePalace.Web.Helpers.PaginatedList<PhonePalace.Web.ViewModels.SupplierIndexViewModel>

@{
    ViewData["Title"] = "Proveedores";
}

<h1>Proveedores</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Nuevo Proveedor</a>
</p>

<div class="row mb-3">
    <div class="col-md-8">
        <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center">
            <label class="form-label mb-0">Mostrar:</label>
            <select name="pageSize" class="form-select" style="width: auto;" onchange="this.form.submit()">
                @{ int pageSize = (int)(ViewData["PageSize"] ?? 10); }
                <option value="10" selected="@(pageSize == 10)">10</option>
                <option value="20" selected="@(pageSize == 20)">20</option>
                <option value="50" selected="@(pageSize == 50)">50</option>
                <option value="100" selected="@(pageSize == 100)">100</option>
            </select>
            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Buscar..." />
            <input type="submit" value="Buscar" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-secondary">Ver Todos</a>
        </form>
    </div>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Nombre / Razón Social</th>
            <th>Documento / NIT</th>
            <th>Tipo</th>
            <th>Email</th>
            <th>Teléfono</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.DisplayName)</td>
                <td>@Html.DisplayFor(modelItem => item.Document)</td>
                <td>@Html.DisplayFor(modelItem => item.SupplierType)</td>
                <td>@Html.DisplayFor(modelItem => item.Email)</td>
                <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactivo</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.SupplierID" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.SupplierID" class="btn btn-sm btn-info">Detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.SupplierID" class="btn btn-sm btn-danger">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<a asp-action="Index"
   asp-route-pageNumber="@(Model.PageIndex - 1)"
   asp-route-currentFilter="@ViewData["CurrentFilter"]"
   asp-route-pageSize="@ViewData["PageSize"]"
   class="btn btn-secondary @prevDisabled">Anterior</a>

<a asp-action="Index"
   asp-route-pageNumber="@(Model.PageIndex + 1)"
   asp-route-currentFilter="@ViewData["CurrentFilter"]"
   asp-route-pageSize="@ViewData["PageSize"]"
   class="btn btn-secondary @nextDisabled">Siguiente</a>