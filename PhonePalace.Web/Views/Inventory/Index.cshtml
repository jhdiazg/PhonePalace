@model IEnumerable<PhonePalace.Web.ViewModels.InventoryIndexViewModel>

@{
    ViewData["Title"] = "Reporte de Inventario";
}

<h1>@ViewData["Title"]</h1>

<div class="row mb-3">
    <div class="col-md-12">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Buscar por nombre o SKU...">
                <button class="btn btn-outline-secondary" type="submit"><i class="bi bi-search"></i> Buscar</button>
                <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.SKU)</th>
                        <th>@Html.DisplayNameFor(model => model.ProductName)</th>
                        <th>@Html.DisplayNameFor(model => model.Cost)</th>
                        <th>@Html.DisplayNameFor(model => model.Price)</th>
                        <th>@Html.DisplayNameFor(model => model.Stock)</th>
                        <th>@Html.DisplayNameFor(model => model.InventoryValue)</th>
                        <th>@Html.DisplayNameFor(model => model.LastUpdated)</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var item in Model) {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.SKU)</td>
                        <td>@Html.DisplayFor(modelItem => item.ProductName)</td>
                        <td>@Html.DisplayFor(modelItem => item.Cost)</td>
                        <td>@Html.DisplayFor(modelItem => item.Price)</td>
                        <td class="fw-bold">@Html.DisplayFor(modelItem => item.Stock)</td>
                        <td>@Html.DisplayFor(modelItem => item.InventoryValue)</td>
                        <td>@Html.DisplayFor(modelItem => item.LastUpdated)</td>
                        <td class="text-end">
                            <a asp-action="Adjust" asp-route-id="@item.ProductID" class="btn btn-sm btn-outline-warning">Ajustar Stock</a>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>
</div>