@model PhonePalace.Domain.Entities.Model

@{
    ViewData["Title"] = "Crear Modelo";
}

<h1>@ViewData["Title"]</h1>

<h4>Modelo de Teléfono</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="BrandID" class="form-label">Marca</label>
                <select asp-for="BrandID" class ="form-control" asp-items="ViewBag.BrandID"><option value="">-- Seleccione una Marca --</option></select>
            </div>
            <div class="mb-3">
                <input type="submit" value="Crear" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Volver a la lista</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}