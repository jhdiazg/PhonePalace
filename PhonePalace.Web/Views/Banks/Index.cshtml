@model IEnumerable<PhonePalace.Domain.Entities.Bank>
@{
    ViewData["Title"] = "Bancos";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}


<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear Nuevo Banco</a>
    <a asp-action="Transfer" class="btn btn-success ms-2">
        <i class="bi bi-arrow-left-right me-2"></i> Nueva Transferencia
    </a>
</p>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>
                            Nombre
                        </th>
                        <th>
                            Número de Cuenta
                        </th>
                        <th>
                            Saldo
                        </th>
                        <th>
                            Activo
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var item in Model) {
                    <tr class="@(item.IsActive ? "" : "table-danger")">
                        <td>
                            @Html.DisplayFor(modelItem => item.Name)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.AccountNumber)
                        </td>
                        <td>
                            @item.Balance.ToString("C")
                        </td>
                        <td>
                            <input type="checkbox" class="form-check-input" disabled @(item.IsActive ? "checked" : "") />
                        </td>
                        <td class="text-end">
                            <a asp-action="Adjust" asp-route-id="@item.BankID" class="btn btn-sm btn-secondary">Ajustar</a>
                            <a asp-action="Edit" asp-route-id="@item.BankID" class="btn btn-sm btn-warning">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.BankID" class="btn btn-sm btn-info">Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.BankID" class="btn btn-sm btn-danger">Eliminar</a>
                        </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>
</div>