@model IEnumerable<PhonePalace.Domain.Entities.Asset>
@using PhonePalace.Domain.Enums

@{
    ViewData["Title"] = "Control de Activos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@ViewData["Title"]</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Registrar Nuevo Activo
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Nombre</th>
                        <th>Descripción / Serial</th>
                        <th>Fecha Adquisición</th>
                        <th>Costo</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Name</td>
                            <td>
                                @item.Description
                                @if(!string.IsNullOrEmpty(item.SerialNumber))
                                {
                                    <br /><small class="text-muted">SN: @item.SerialNumber</small>
                                }
                            </td>
                            <td>@item.AcquisitionDate.ToShortDateString()</td>
                            <td>@item.AcquisitionCost.ToString("C0")</td>
                            <td>
                                @if(item.Status == AssetStatus.Active)
                                { 
                                    <span class="badge bg-success">Activo</span>
                                }
                                else if (item.Status == AssetStatus.Decommissioned)
                                {
                                    <span class="badge bg-danger">Dado de Baja</span>
                                }
                                else if (item.Status == AssetStatus.Sold)
                                {
                                    <span class="badge bg-warning text-dark">Vendido</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status</span>
                                }
                            </td>
                            <td>
                                @if(item.Status == AssetStatus.Active)
                                {
                                    <form asp-action="Retire" asp-route-id="@item.AssetID" method="post" onsubmit="return confirm('¿Está seguro de dar de baja este activo? Dejará de sumar en el balance.');">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">Dar de Baja</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>