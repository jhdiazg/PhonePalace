@model PhonePalace.Web.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Dashboard</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">Resumen General</li>
    </ol>

    <div class="row">
        <div class="col-xl-3 col-md-6">
            <div class="card bg-primary text-white mb-4">
                <div class="card-body">
                    <h4 class="mb-0">@Model.TotalClients</h4>
                    <div>Clientes Activos</div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <a class="small text-white stretched-link" asp-controller="Clients" asp-action="Index">Ver Detalles</a>
                    <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card bg-warning text-white mb-4">
                <div class="card-body">
                    <h4 class="mb-0">@Model.TotalProducts</h4>
                    <div>Productos Activos</div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <a class="small text-white stretched-link" asp-controller="Products" asp-action="Index">Ver Detalles</a>
                    <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card bg-success text-white mb-4">
                <div class="card-body">
                    <h4 class="mb-0">@Model.CurrentMonthSales.ToString("C")</h4>
                    <div>Ventas del Mes</div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <a class="small text-white stretched-link" asp-controller="Sales" asp-action="Index">Ver Detalles</a>
                    <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card bg-primary text-white mb-4">
                <div class="card-body">
                    <h4 class="mb-0">@Model.TotalInventoryValue.ToString("C")</h4>
                    <div>Valor Inventario</div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <a class="small text-white stretched-link" asp-controller="Inventory" asp-action="Index">Ver Detalles</a>
                    <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card bg-info text-white mb-4">
                <div class="card-body">
                    <h4 class="mb-0">@Model.CashBalance.ToString("C0")</h4>
                    <div>Saldo en Caja</div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <a class="small text-white stretched-link" asp-controller="Reports" asp-action="CashMovements">Ver Movimientos</a>
                    <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card bg-dark text-white mb-4">
                <div class="card-body">
                    <h4 class="mb-0">@Model.BanksBalance.ToString("C0")</h4>
                    <div>Saldo en Bancos</div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <a class="small text-white stretched-link" asp-controller="Reports" asp-action="BankTransactions">Ver Transacciones</a>
                    <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card bg-secondary text-white mb-4">
                <div class="card-body">
                    <h4 class="mb-0">@Model.TotalAccountsReceivable.ToString("C0")</h4>
                    <div>Cuentas por Cobrar</div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <a class="small text-white stretched-link" asp-controller="AccountReceivables" asp-action="Index">Ver Detalles</a>
                    <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                </div>
            </div>
        </div>
        <!-- Tarjeta Cuentas por Pagar -->
        <div class="col-xl-3 col-md-6">
            <div class="card bg-danger text-white mb-4">
                <div class="card-body">
                    <h4 class="mb-0">@Model.TotalAccountsPayable.ToString("C")</h4>
                    <div>Cuentas Por Pagar</div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <a class="small text-white stretched-link" asp-controller="AccountPayables" asp-action="Index">Ver Detalles</a>
                    <div class="small text-white"><i class="fas fa-angle-right"></i></div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-xl-6 mb-4">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fas fa-exclamation-triangle me-1"></i>
                    Productos con Bajo Stock
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Producto</th>
                                    <th>Stock Actual</th>
                                    <th>Nivel Reorden</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.LowStockProducts != null && Model.LowStockProducts.Any())
                                {
                                    foreach (var item in Model.LowStockProducts)
                                    {
                                        <tr>
                                            <td>@item.ProductName</td>
                                            <td class="text-danger fw-bold">@item.CurrentStock</td>
                                            <td>@item.ReorderLevel</td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center">No hay alertas de stock bajo.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-6 mb-4">
            <div class="card mb-4">
                <div class="card-header">
                    <i class="fas fa-chart-bar me-1"></i>
                    Distribución de Ventas por Margen de Utilidad (Mes Actual)
                </div>
                <div class="card-body">
                    <canvas id="marginChart" width="100%" height="50"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/2.8.0/Chart.min.js" crossorigin="anonymous"></script>
    <script>
        // Obtener datos del modelo
        var marginLabels = @Html.Raw(Json.Serialize(Model.SalesByMargin.Select(x => x.RangeLabel)));
        var marginData = @Html.Raw(Json.Serialize(Model.SalesByMargin.Select(x => x.Quantity)));

        var ctx = document.getElementById("marginChart");
        var myLineChart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: marginLabels,
                datasets: [{
                    label: "Cantidad de Productos",
                    backgroundColor: [
                        "rgba(220, 53, 69, 0.8)",  // Rojo (Pérdida)
                        "rgba(255, 193, 7, 0.8)",  // Amarillo (Bajo)
                        "rgba(23, 162, 184, 0.8)", // Azul Claro (Medio)
                        "rgba(40, 167, 69, 0.8)",  // Verde (Alto)
                        "rgba(33, 37, 41, 0.8)"    // Oscuro (Muy Alto)
                    ],
                    borderColor: "rgba(2,117,216,1)",
                    data: marginData,
                }],
            },
            options: {
                scales: {
                    yAxes: [{
                        ticks: {
                            beginAtZero: true
                        }
                    }]
                },
                legend: { display: false }
            }
        });
    </script>
}