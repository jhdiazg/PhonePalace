@model PhonePalace.Web.ViewModels.AuditLogIndexViewModel

@{
    ViewData["Title"] = "Auditoría del Sistema";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning">
        @TempData["Warning"]
    </div>
}
@if (TempData["Info"] != null)
{
    <div class="alert alert-info">
        @TempData["Info"]
    </div>
}

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label">Módulo</label>
                <select name="selectedModule" class="form-select" asp-items="Model.ModuleList">
                    <option value="">Todos</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Usuario</label>
                <input type="text" name="searchUser" value="@Model.SearchUser" class="form-control" placeholder="Usuario..." />
            </div>
            <div class="col-md-2">
                <label class="form-label">Fecha Inicio</label>
                <input type="date" name="startDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Fecha Fin</label>
                <input type="date" name="endDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Mostrar</label>
                <select name="pageSize" class="form-select" onchange="this.form.submit()">
                    @{ int pageSize = (int)(ViewData["PageSize"] ?? 10); }
                    <option value="10" selected="@(pageSize == 10)">10</option>
                    <option value="20" selected="@(pageSize == 20)">20</option>
                    <option value="50" selected="@(pageSize == 50)">50</option>
                    <option value="100" selected="@(pageSize == 100)">100</option>
                </select>
            </div>
            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Filtrar</button>
                <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
            </div>
        </form>
    </div>
</div>

<div class="mb-3">
    <a asp-action="ExportToExcel" 
       asp-route-selectedModule="@Model.SelectedModule"
       asp-route-searchUser="@Model.SearchUser"
       asp-route-startDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
       asp-route-endDate="@Model.EndDate?.ToString("yyyy-MM-dd")"
       class="btn btn-success">
        <i class="bi bi-file-earmark-excel"></i> Exportar a Excel
    </a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-light">
            <tr>
                <th>Fecha y Hora</th>
                <th>Usuario</th>
                <th>Módulo</th>
                <th>Descripción</th>
                <th>IP</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.AuditLogs!)
            {
                <tr>
                    <td>@item.Timestamp.ToString("dd/MM/yyyy HH:mm:ss")</td>
                    <td>@item.UserName</td>
                    <td><span class="badge bg-info text-dark">@item.Origin</span></td>
                    <td>@item.Description</td>
                    <td><small class="text-muted">@item.IPAddress</small></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    var prevDisabled = !Model.AuditLogs.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.AuditLogs.HasNextPage ? "disabled" : "";
}

<div class="d-flex justify-content-center align-items-center mt-3">
    <a asp-action="Index"
       asp-route-page="@(Model.AuditLogs.PageIndex - 1)"
       asp-route-selectedModule="@Model.SelectedModule"
       asp-route-searchUser="@Model.SearchUser"
       asp-route-startDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
       asp-route-endDate="@Model.EndDate?.ToString("yyyy-MM-dd")"
       asp-route-pageSize="@ViewData["PageSize"]"
       class="btn btn-secondary @prevDisabled">
        Anterior
    </a>
    <span class="mx-3">Página @Model.AuditLogs.PageIndex de @Model.AuditLogs.TotalPages</span>
    <a asp-action="Index"
       asp-route-page="@(Model.AuditLogs.PageIndex + 1)"
       asp-route-selectedModule="@Model.SelectedModule"
       asp-route-searchUser="@Model.SearchUser"
       asp-route-startDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
       asp-route-endDate="@Model.EndDate?.ToString("yyyy-MM-dd")"
       asp-route-pageSize="@ViewData["PageSize"]"
       class="btn btn-secondary @nextDisabled">
        Siguiente
    </a>
</div>