@model PhonePalace.Web.Models.AuditLogIndexViewModel


@{
    ViewData["Title"] = "Registro de Auditoría";
}

<h1>@ViewData["Title"]</h1>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h5 class="mb-0">Filtros</h5>
    </div>
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-2">
                <label asp-for="SelectedModule" class="form-label"></label>
                <select asp-for="SelectedModule" asp-items="@Model.ModuleList" class="form-select">
                    <option value="">Todos</option>
                </select>
            </div>
            <div class="col-md-3">
                <label asp-for="SearchUser" class="form-label"></label>
                <input asp-for="SearchUser" class="form-control" />
            </div>
            <div class="col-md-2">
                <label asp-for="StartDate" class="form-label"></label>
                <input asp-for="StartDate" class="form-control" type="date" />
            </div>
            <div class="col-md-2">
                <label asp-for="EndDate" class="form-label"></label>
                <input asp-for="EndDate" class="form-control" type="date" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-success w-100" formaction="@Url.Action("ExportToExcel")">
                    <i class="bi bi-file-earmark-excel-fill me-1"></i> Exportar
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Fecha y Hora (UTC)</th>
                        <th>Usuario</th>
                        <th>Módulo</th>
                        <th>Descripción</th>
                        <th>Dirección IP</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.AuditLogs != null && Model.AuditLogs.Any())
                    {
                        @foreach (var item in Model.AuditLogs)
                        {
                            <tr>
                                <td>@item.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@Html.DisplayFor(modelItem => item.UserName)</td>
                                <td>@Html.DisplayFor(modelItem => item.Origin)</td>
                                <td>@Html.DisplayFor(modelItem => item.Description)</td>
                                <td>@Html.DisplayFor(modelItem => item.IPAddress)</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center">No se encontraron registros.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    @if (Model.AuditLogs != null && Model.AuditLogs.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-center align-items-center">
            @{
                var prevDisabled = !Model.AuditLogs.HasPreviousPage ? "disabled" : "";
                var nextDisabled = !Model.AuditLogs.HasNextPage ? "disabled" : "";
            }
            <a asp-action="Index"
               asp-route-page="@(Model.AuditLogs.PageIndex - 1)"
               asp-route-selectedModule="@Model.SelectedModule"
               asp-route-searchUser="@Model.SearchUser"
               asp-route-startDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
               asp-route-endDate="@Model.EndDate?.ToString("yyyy-MM-dd")"
               class="btn btn-outline-secondary @prevDisabled">
                Anterior
            </a>
            <span class="mx-3">Página @Model.AuditLogs.PageIndex de @Model.AuditLogs.TotalPages</span>
            <a asp-action="Index"
               asp-route-page="@(Model.AuditLogs.PageIndex + 1)"
               asp-route-selectedModule="@Model.SelectedModule"
               asp-route-searchUser="@Model.SearchUser"
               asp-route-startDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
               asp-route-endDate="@Model.EndDate?.ToString("yyyy-MM-dd")"
               class="btn btn-outline-secondary @nextDisabled">
                Siguiente
            </a>
        </div>
    }
</div>