@model PhonePalace.Web.ViewModels.UserEditViewModel

@{
    ViewData["Title"] = "Editar Usuario";
}

<h1>@ViewData["Title"]</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="ProfilePictureUrl" />

            <div class="row">
                <div class="col-md-4 text-center mb-3">
                    @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                    {
                        <img src="@Url.Content("~/" + Model.ProfilePictureUrl.TrimStart('/'))" alt="Foto de Perfil" class="img-thumbnail rounded-circle mb-2" style="width: 150px; height: 150px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded-circle mx-auto mb-2" style="width: 150px; height: 150px;">
                            <span class="display-4">@(Model.UserName?.Substring(0, 1).ToUpper() ?? "U")</span>
                        </div>
                    }
                    <div class="mb-3">
                        <label asp-for="ProfilePictureFile" class="form-label">Cambiar Foto</label>
                        <input asp-for="ProfilePictureFile" class="form-control" type="file" accept="image/*" />
                        <span asp-validation-for="ProfilePictureFile" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-md-8">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UserName" class="form-label"></label>
                            <input asp-for="UserName" class="form-control" />
                            <span asp-validation-for="UserName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" readonly />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control" />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Roles Asignados</label>
                        <div class="border p-2 rounded" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var role in Model.AvailableRoles)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="SelectedRoles" value="@role"
                                           id="role_@role" @(Model.SelectedRoles.Contains(role) ? "checked" : "") />
                                    <label class="form-check-label" for="role_@role">
                                        @role
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3 d-flex justify-content-end">
                <a asp-action="ChangePassword" asp-route-id="@Model.UserId" class="btn btn-warning me-2"><i class="bi bi-key-fill"></i> Cambiar Contraseña</a>
                <a asp-action="Index" class="btn btn-secondary me-2">Cancelar</a>
                <button type="submit" class="btn btn-primary">Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}