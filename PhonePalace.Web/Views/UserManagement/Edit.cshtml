@model PhonePalace.Web.ViewModels.EditUserRolesViewModel

@{
    ViewData["Title"] = "Editar Roles de Usuario";
}

<h1>@ViewData["Title"]</h1>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Usuario</label>
                        <input type="text" class="form-control" value="@Model.UserName" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" value="@Model.Email" readonly />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label">Roles Disponibles</label>
                        <div class="border p-2" style="max-height: 200px; overflow-y: auto;">
                            @foreach (var role in Model.AvailableRoles)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="SelectedRoles" value="@role"
                                           id="role_@role" @(Model.SelectedRoles.Contains(role) ? "checked" : "") />
                                    <label class="form-check-label" for="role_@role">
                                        @role
                                    </label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>