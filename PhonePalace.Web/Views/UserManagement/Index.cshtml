@model IEnumerable<PhonePalace.Web.ViewModels.UserRolesViewModel>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Crear Nuevo Usuario</a>
</p>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Usuario</th>
                        <th>Email</th>
                        <th>Roles</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.UserName</td>
                            <td>@user.Email</td>
                            <td>
                                @if (user.Roles.Any())
                                {
                                    <span class="badge bg-primary">@string.Join(", ", user.Roles)</span>
                                }
                                else
                                {
                                    <span class="text-muted">Sin roles</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@user.UserId" class="btn btn-sm btn-primary">Editar Roles</a>
                                @if (user.Roles.Contains("Administrador"))
                                {
                                    <button class="btn btn-sm btn-secondary" disabled title="No se puede bloquear a un administrador">Bloquear</button>
                                }
                                else
                                {
                                    @if (user.IsLocked)
                                    {
                                        <form asp-action="Unlock" asp-route-id="@user.UserId" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success" onclick="return confirm('¿Desbloquear este usuario?')">Desbloquear</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form asp-action="Lock" asp-route-id="@user.UserId" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('¿Bloquear este usuario?')">Bloquear</button>
                                        </form>
                                    }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>