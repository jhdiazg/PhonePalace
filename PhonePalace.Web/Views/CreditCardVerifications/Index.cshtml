@model PhonePalace.Web.Helpers.PaginatedList<PhonePalace.Domain.Entities.CreditCardVerification>

@{
    ViewData["Title"] = "Verificación de Tarjetas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@ViewData["Title"]</h1>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Origen</th>
                        <th>Banco</th>
                        <th class="text-end">Monto Sistema</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CreationDate.ToString("g")</td>
                            <td>
                                @if (item.SaleID.HasValue)
                                {
                                    <a asp-controller="Sales" asp-action="Details" asp-route-id="@item.SaleID">
                                        Venta #@item.SaleID
                                    </a>
                                    <br />
                                    <small class="text-muted">@item.Sale?.Client?.DisplayName</small>
                                }
                                else if (item.AccountReceivablePaymentID.HasValue)
                                {
                                    <a asp-controller="AccountReceivables" asp-action="Details" asp-route-id="@item.AccountReceivablePayment?.AccountReceivableID">
                                        Abono CxC #@item.AccountReceivablePayment?.AccountReceivableID
                                    </a>
                                    <br />
                                    <small class="text-muted">@item.AccountReceivablePayment?.AccountReceivable?.Client?.DisplayName</small>
                                }
                            </td>
                            <td>@item.Bank?.Name</td>
                            <td class="text-end fw-bold">@item.Amount.ToString("C")</td>
                            <td class="text-center">
                                <button type="button" class="btn btn-success btn-sm" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#verifyModal" 
                                        data-id="@item.CreditCardVerificationID" 
                                        data-amount="@item.Amount">
                                    <i class="bi bi-check-circle"></i> Verificar
                                </button>
                                <button type="button" class="btn btn-danger btn-sm" 
                                        data-bs-toggle="modal" 
                                        data-bs-target="#rejectModal" 
                                        data-id="@item.CreditCardVerificationID">
                                    <i class="bi bi-x-circle"></i> Rechazar
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        <!-- Paginación básica -->
        <div class="d-flex justify-content-center mt-3">
            @if (Model.HasPreviousPage)
            {
                <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)" class="btn btn-outline-secondary me-2">Anterior</a>
            }
            @if (Model.HasNextPage)
            {
                <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)" class="btn btn-outline-secondary">Siguiente</a>
            }
        </div>
    </div>
</div>

<!-- Modal Verificar -->
<div class="modal fade" id="verifyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" id="verifyForm">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Verificar Transacción</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> Ingrese el valor exacto que aparece en el extracto bancario. El sistema calculará automáticamente la comisión.
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Monto en Sistema:</label>
                        <input type="text" class="form-control" id="systemAmountDisplay" readonly disabled>
                    </div>
                    <div class="mb-3">
                        <label for="realAmount" class="form-label fw-bold">Valor Real en Banco</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" class="form-control" id="realAmount" name="realAmount" step="0.01" min="0.01" required>
                        </div>
                        <div class="form-text">Si el valor es menor al del sistema, la diferencia se registrará como "Gasto comisiones bancarias".</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-success">Confirmar Verificación</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal Rechazar -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" id="rejectForm">
                @Html.AntiForgeryToken()
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Rechazar Transacción</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>¿Está seguro de rechazar esta transacción? Esto no afectará el saldo del banco.</p>
                    <div class="mb-3">
                        <label for="reason" class="form-label">Motivo del rechazo</label>
                        <textarea class="form-control" id="reason" name="reason" rows="3" required placeholder="Ej: Transacción no encontrada en el banco..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-danger">Confirmar Rechazo</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var verifyModal = document.getElementById('verifyModal');
        verifyModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-id');
            var amount = button.getAttribute('data-amount');
            
            // Configurar URL del formulario
            var form = verifyModal.querySelector('#verifyForm');
            form.action = '/VerificacionTarjeta/Verify/' + id;
            
            // Mostrar monto del sistema
            var displayInput = verifyModal.querySelector('#systemAmountDisplay');
            // Formatear como moneda si es posible, o mostrar valor crudo
            var formatter = new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP' });
            displayInput.value = formatter.format(amount);

            // Limpiar input de valor real
            var realInput = verifyModal.querySelector('#realAmount');
            realInput.value = '';
            realInput.focus();
        });

        var rejectModal = document.getElementById('rejectModal');
        rejectModal.addEventListener('show.bs.modal', function (event) {
            var button = event.relatedTarget;
            var id = button.getAttribute('data-id');
            
            var form = rejectModal.querySelector('#rejectForm');
            form.action = '/VerificacionTarjeta/Reject/' + id;
        });
    </script>
}