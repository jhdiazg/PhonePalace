@model PhonePalace.Domain.Entities.Quote

@{
    ViewData["Title"] = "Detalles de Cotización";
    var taxRate = ViewBag.TaxRate != null ? (decimal)ViewBag.TaxRate : 0.19m;
}

<h1>@ViewData["Title"]</h1>

<div class="card shadow-sm mb-4">
    <div class="card-header">
        <h5 class="mb-0">Información General</h5>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-2">ID</dt>
            <dd class="col-sm-10">@Model.QuoteID</dd>
            <dt class="col-sm-2">Cliente</dt>
            <dd class="col-sm-10">@Model.Client.DisplayName</dd>
            <dt class="col-sm-2">Fecha</dt>
            <dd class="col-sm-10">@Model.QuoteDate.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-2">Vencimiento</dt>
            <dd class="col-sm-10">@Model.ExpirationDate.ToString("dd/MM/yyyy")</dd>
            <dt class="col-sm-2">Estado</dt>
            <dd class="col-sm-10">@Model.Status</dd>
        </dl>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0">Productos</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Cantidad</th>
                        <th>Precio Unit.</th>
                        <th>Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Details)
                    {
                        <tr>
                            <td>@item.Product.Name</td>
                            <td>@item.Quantity</td>
                            <td>@item.UnitPrice.ToString("C")</td>
                            <td>@((item.Quantity * item.UnitPrice).ToString("C"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="3" class="text-end">Subtotal:</td>
                        <td>@Model.Subtotal.ToString("C")</td>
                    </tr>
                    <tr>
                        <td colspan="3" class="text-end">IVA (@(taxRate * 100)%):</td>
                        <td>@Model.Tax.ToString("C")</td>
                    </tr>
                    <tr>
                        <td colspan="3" class="text-end fw-bold">Total:</td>
                        <td class="fw-bold">@Model.Total.ToString("C")</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <form asp-action="ConvertToSale" asp-route-id="@Model.QuoteID" method="post" class="d-inline">
        <button type="submit" class="btn btn-success">Convertir a Venta</button>
    </form>
    <a asp-action="Edit" asp-route-id="@Model.QuoteID" class="btn btn-warning">Editar</a>
    <a asp-action="Index" class="btn btn-secondary">Volver a la Lista</a>
</div>