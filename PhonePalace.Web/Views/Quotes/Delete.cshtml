@model PhonePalace.Domain.Entities.Quote

@{
    ViewData["Title"] = "Eliminar Cotización";
}

<h1>@ViewData["Title"]</h1>

<h3 class="text-danger">¿Está seguro de que desea eliminar esta cotización?</h3>
<p class="text-danger">Esta acción no se puede deshacer.</p>

<div class="card mt-3">
    <div class="card-header">
        <h4>Cotización #@Model.QuoteID</h4>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Client)
            </dt>
            <dd class="col-sm-9">
                @Html.DisplayFor(model => model.Client.DisplayName)
            </dd>
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.QuoteDate)
            </dt>
            <dd class="col-sm-9">
                @Model.QuoteDate.ToShortDateString()
            </dd>
            <dt class="col-sm-3">
                @Html.DisplayNameFor(model => model.Total)
            </dt>
            <dd class="col-sm-9">
                @Model.Total.ToString("C")
            </dd>
        </dl>

        <form asp-action="Delete" class="mt-3">
            <input type="hidden" asp-for="QuoteID" />
            <input type="submit" value="Eliminar Definitivamente" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </form>
    </div>
</div>