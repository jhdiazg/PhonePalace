@model PhonePalace.Web.ViewModels.QuoteCreateViewModel

@{
    ViewData["Title"] = "Crear Nueva Cotización";
}

<h1>@ViewData["Title"]</h1>
<hr />

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="ClientID" class="form-label"></label>
            <select asp-for="ClientID" class="form-select" asp-items="Model.Clients">
                <option value="">-- Seleccione un Cliente --</option>
            </select>
            <span asp-validation-for="ClientID" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="QuoteDate" class="form-label"></label>
            <input asp-for="QuoteDate" class="form-control" />
            <span asp-validation-for="QuoteDate" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="ExpirationDate" class="form-label"></label>
            <input asp-for="ExpirationDate" class="form-control" />
            <span asp-validation-for="ExpirationDate" class="text-danger"></span>
        </div>
    </div>

    <h4 class="mt-4">Detalles de la Cotización</h4>
    <hr />

    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Producto</th>
                <th style="width: 100px;">Cantidad</th>
                <th style="width: 150px;">Precio Unit.</th>
                <th style="width: 150px;">Subtotal</th>
                <th style="width: 50px;"></th>
            </tr>
        </thead>
        <tbody id="quote-details-body">
            @* Las filas de detalles se agregarán aquí dinámicamente *@
        </tbody>
        <tfoot>
            <tr>
                <th colspan="2"></th>
                <th class="text-end">Total:</th>
                <th id="grand-total" class="fw-bold"></th>
                <th></th>
            </tr>
        </tfoot>
    </table>

    <button type="button" id="add-product-btn" class="btn btn-success mb-3">
        <i class="bi bi-plus-circle"></i> Añadir Producto
    </button>

    <div class="form-group mt-4">
        <input type="submit" value="Crear Cotización" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>

<!-- Plantilla para nuevas filas de detalles (oculta) -->
<table class="d-none">
    <tbody id="detail-row-template">
        <tr>
            <td>
                <input type="text" class="form-control product-name-display" data-name="ProductName" readonly />
            </td>
            <td>
                <input type="number" value="1" min="1" class="form-control quantity-input" data-name="Quantity" />
            </td>
            <td>
                <input type="number" step="0.01" class="form-control price-input" data-name="UnitPrice" />
            </td>
            <td>
                <input type="text" class="form-control subtotal-display" readonly />
            </td>
            <td>
                <button type="button" class="btn btn-danger btn-sm delete-row-btn">
                    <i class="bi bi-trash"></i>
                </button>
            </td>
        </tr>
    </tbody>
</table>


@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const addProductBtn = document.getElementById('add-product-btn');
            const detailsBody = document.getElementById('quote-details-body');
            const template = document.getElementById('detail-row-template').querySelector('tr');
            const grandTotalEl = document.getElementById('grand-total');

            const currencyFormatter = new Intl.NumberFormat('es-DO', {
                style: 'currency',
                currency: 'DOP'
            });

            function formatCurrency(value) {
                return currencyFormatter.format(value || 0);
            }

            addProductBtn.addEventListener('click', addProductRow);

            function addProductRow() {
                const newRow = template.cloneNode(true);
                detailsBody.appendChild(newRow);
                attachRowEventListeners(newRow);
                reindexRows();
            }

            function reindexRows() {
                const rows = detailsBody.querySelectorAll('tr');
                rows.forEach((row, index) => {
                    row.querySelectorAll('input, select').forEach(input => {
                        const propertyName = input.dataset.name;
                        if (propertyName) {
                            input.name = `Details[${index}].${propertyName}`;
                        }
                    });
                });
                updateGrandTotal();
            }

            function attachRowEventListeners(row) {
                row.querySelector('.delete-row-btn').addEventListener('click', function () {
                    row.remove();
                    reindexRows();
                });

                const productSelect = row.querySelector('.product-select');
                const priceInput = row.querySelector('.price-input');
                const quantityInput = row.querySelector('.quantity-input');

                productSelect.addEventListener('change', function () {
                    const productId = this.value;
                    if (productId) {
                        fetch(`@Url.Action("GetProductPrice", "Quotes")?productId=${productId}`)
                            .then(response => {
                                if (!response.ok) throw new Error('Network response was not ok');
                                return response.json();
                            })
                            .then(data => {
                                priceInput.value = data.price.toFixed(2);
                                updateSubtotal(row);
                            })
                            .catch(error => console.error('Error al obtener el precio:', error));
                    } else {
                        priceInput.value = '';
                        updateSubtotal(row);
                    }
                });

                quantityInput.addEventListener('input', () => updateSubtotal(row));
                priceInput.addEventListener('input', () => updateSubtotal(row));
            }

            function updateSubtotal(row) {
                const quantity = parseFloat(row.querySelector('.quantity-input').value) || 0;
                const price = parseFloat(row.querySelector('.price-input').value) || 0;
                const subtotal = quantity * price;
                row.querySelector('.subtotal-display').value = formatCurrency(subtotal);
                updateGrandTotal();
            }

            function updateGrandTotal() {
                let grandTotal = 0;
                const rows = detailsBody.querySelectorAll('tr');
                rows.forEach(row => {
                    const quantity = parseFloat(row.querySelector('.quantity-input').value) || 0;
                    const price = parseFloat(row.querySelector('.price-input').value) || 0;
                    grandTotal += quantity * price;
                });
                grandTotalEl.textContent = formatCurrency(grandTotal);
            }

            // Añadir una fila inicial al cargar la página
            addProductRow();
            updateGrandTotal(); // Inicializa el total
        });
    </script>
}
