@model PhonePalace.Web.ViewModels.SalesReportViewModel
@using PhonePalace.Web.Helpers
@using PhonePalace.Web.ViewModels

@{
    ViewData["Title"] = "Reporte de Ventas por Forma de Pago";
}

<div class="container-fluid">
    <h2 class="mb-4">@ViewData["Title"]</h2>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="SalesByPaymentMethod" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Fecha Inicio</label>
                    <input type="date" name="startDate" class="form-control" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Fecha Fin</label>
                    <input type="date" name="endDate" class="form-control" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Forma de Pago</label>
                    <select name="selectedPaymentMethod" class="form-select" asp-for="SelectedPaymentMethod" asp-items="Model.PaymentMethods">
                        <option value="">Todos los métodos</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1">Filtrar</button>
                    <a asp-action="SalesByPaymentMethod" class="btn btn-secondary flex-grow-1">Limpiar</a>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        <!-- Resumen -->
        <div class="col-md-4">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Resumen por Método</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Método</th>
                                <th class="text-end">Cant.</th>
                                <th class="text-end">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Summary)
                            {
                                <tr>
                                    <td>@item.PaymentMethod</td>
                                    <td class="text-end">@item.Count</td>
                                    <td class="text-end">@item.TotalAmount.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-dark">
                                <td><strong>TOTAL</strong></td>
                                <td class="text-end"><strong>@Model.Summary.Sum(x => x.Count)</strong></td>
                                <td class="text-end"><strong>@Model.TotalSales.ToString("C")</strong></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Detalle -->
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Detalle de Transacciones</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Factura</th>
                                    <th>Cliente</th>
                                    <th>Método</th>
                                    <th>Ref.</th>
                                    <th class="text-end">Monto</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Details ?? Enumerable.Empty<PaymentDetailDto>())
                                {
                                    <tr>
                                        <td>@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>
                                            @if (item.SaleId.HasValue)
                                            {
                                                <a asp-controller="Sales" asp-action="Details" asp-route-id="@item.SaleId">#@item.InvoiceId</a>
                                            }
                                            else
                                            {
                                                <span>#@item.InvoiceId</span>
                                            }
                                        </td>
                                        <td>@item.ClientName</td>
                                        <td>@item.PaymentMethod</td>
                                        <td>@item.Reference</td>
                                        <td class="text-end">@item.Amount.ToString("C")</td>
                                    </tr>
                                }
                                @if (Model.Details == null || !Model.Details.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted">No hay registros en este rango de fechas.</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Controles de Paginación -->
                    @{
                        var prevDisabled = Model.Details == null || !Model.Details.HasPreviousPage ? "disabled" : "";
                        var nextDisabled = Model.Details == null || !Model.Details.HasNextPage ? "disabled" : "";
                    }
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <div>
                            <a asp-action="SalesByPaymentMethod"
                               asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
                               asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")"
                               asp-route-selectedPaymentMethod="@Model.SelectedPaymentMethod"
                               asp-route-pageNumber="@((Model.Details?.PageIndex ?? 1) - 1)"
                               asp-route-pageSize="@ViewData["PageSize"]"
                               class="btn btn-outline-secondary @prevDisabled">
                                Anterior
                            </a>
                            <a asp-action="SalesByPaymentMethod"
                               asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
                               asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")"
                               asp-route-selectedPaymentMethod="@Model.SelectedPaymentMethod"
                               asp-route-pageNumber="@((Model.Details?.PageIndex ?? 1) + 1)"
                               asp-route-pageSize="@ViewData["PageSize"]"
                               class="btn btn-outline-secondary @nextDisabled">
                                Siguiente
                            </a>
                        </div>
                        <div class="text-muted">
                            Página @(Model.Details?.PageIndex ?? 1) de @(Model.Details?.TotalPages ?? 1)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>