@model IEnumerable<PhonePalace.Web.ViewModels.ProductImageViewModel>

@if (Model.Any())
{
    <div class="row g-2">
        @foreach (var image in Model)
        {
            <div class="col-6 col-sm-4 col-md-6">
                <div class="card h-100">
                    <img src="@image.ImageUrl" class="card-img-top" style="aspect-ratio: 1 / 1; object-fit: cover;" alt="Imagen de producto">
                    <div class="card-body p-2 text-center">
                        @if (image.IsPrimary)
                        {
                            <span class="badge bg-success mb-2">Principal</span>
                        }
                        <div class="btn-group btn-group-sm" role="group">
                            @if (!image.IsPrimary)
                            {
                                <form asp-action="SetPrimaryImage" method="post" class="d-inline image-action-form">
                                    <input type="hidden" name="imageId" value="@image.ProductImageID" />
                                    <input type="hidden" name="productId" value="@ViewData["ProductID"]" />
                                    <button type="submit" class="btn btn-outline-success" title="Marcar como principal">⭐</button>
                                </form>
                            }
                            <form asp-action="DeleteImage" method="post" class="d-inline image-action-form">
                                <input type="hidden" name="imageId" value="@image.ProductImageID" />
                                <input type="hidden" name="productId" value="@ViewData["ProductID"]" />
                                <button type="submit" class="btn btn-outline-danger" title="Eliminar imagen" onclick="return confirm('¿Está seguro de que desea eliminar esta imagen?');">🗑️</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info" role="alert">
        Este producto aún no tiene imágenes.
    </div>
}