@using Microsoft.AspNetCore.Identity
@using PhonePalace.Infrastructure.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    <li class="nav-item">
        <a class="nav-link d-flex align-items-center" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            @if (user != null && !string.IsNullOrEmpty(user.ProfilePictureUrl))
            {
                <img src="@Url.Content("~/" + user.ProfilePictureUrl.TrimStart('/'))" alt="Perfil" class="rounded-circle me-2" style="width: 32px; height: 32px; object-fit: cover;" />
            }
            else
            {
                <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded-circle me-2" style="width: 32px; height: 32px;">
                    <span style="font-size: 0.8rem;">@((user?.UserName ?? User.Identity?.Name ?? "U").Substring(0, 1).ToUpper())</span>
                </div>
            }
            @(user?.UserName ?? User.Identity?.Name)
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link">Cerrar Sesión</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link" asp-area="Identity" asp-page="/Account/Login">Iniciar Sesión</a>
    </li>
}
</ul>