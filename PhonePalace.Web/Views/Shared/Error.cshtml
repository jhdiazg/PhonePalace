@model PhonePalace.Web.ViewModels.ErrorViewModel
@using Microsoft.AspNetCore.Diagnostics
@{
    ViewData["Title"] = "Error";
    Layout = null; // IMPORTANTE: Desactivar Layout para evitar errores en cascada (ej. DB caída al cargar menú)
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Error - PhonePalace</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="card border-danger shadow-lg">
            <div class="card-header bg-danger text-white">
                <h3 class="mb-0">Error Crítico del Sistema</h3>
            </div>
            <div class="card-body">
                <h4 class="text-danger">Ocurrió un error al procesar su solicitud.</h4>
                
                @if (Model.ShowRequestId)
                {
                    <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
                }

                @{
                    var exceptionFeature = Context.Features.Get<IExceptionHandlerPathFeature>();
                }

                @if (exceptionFeature != null)
                {
                    <div class="alert alert-warning mt-3">
                        <h5>Diagnóstico (Producción):</h5>
                        <p><strong>Error:</strong> @exceptionFeature.Error.Message</p>
                        <p><strong>Ruta:</strong> @exceptionFeature.Path</p>
                        <hr/>
                        <details>
                            <summary class="fw-bold">Ver Stack Trace Completo</summary>
                            <pre class="mt-2 bg-white p-2 border" style="white-space: pre-wrap; font-size: 0.85rem;">@exceptionFeature.Error.StackTrace</pre>
                        </details>
                    </div>
                }
                else
                {
                    <div class="alert alert-info mt-3">
                        No se detectó información de excepción. Si está viendo esto después de un Login fallido, verifique la conexión a la base de datos.
                    </div>
                }
                
                <div class="mt-4">
                    <a href="/" class="btn btn-secondary">Volver al Inicio</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>