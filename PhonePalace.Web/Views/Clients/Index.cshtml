@using PhonePalace.Web.Helpers
@model PaginatedList<PhonePalace.Web.ViewModels.ClientIndexViewModel>

@{
    ViewData["Title"] = "Clientes";
}

<h1>@ViewData["Title"]</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Crear Nuevo Cliente</a>
</p>

<div class="row mb-3">
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex gap-2 align-items-center">
            <label class="form-label mb-0">Mostrar:</label>
            <select name="pageSize" class="form-select" style="width: auto;" onchange="this.form.submit()">
                @{ int pageSize = (int)(ViewData["PageSize"] ?? 10); }
                <option value="10" selected="@(pageSize == 10)">10</option>
                <option value="20" selected="@(pageSize == 20)">20</option>
                <option value="50" selected="@(pageSize == 50)">50</option>
                <option value="100" selected="@(pageSize == 100)">100</option>
            </select>
            <input type="text" name="searchString" class="form-control" placeholder="Buscar por nombre o documento..." value="@ViewData["CurrentFilter"]" />
            <button type="submit" class="btn btn-primary">Buscar</button>
            @if (ViewData["CurrentFilter"] != null)
            {
                <a asp-action="Index" class="btn btn-secondary">Limpiar</a>
            }
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Tipo</th>
                        <th>Nombre / Razón Social</th>
                        <th>Documento</th>
                        <th>Correo Electrónico</th>
                        <th>Teléfono</th>
                        <th>Activo</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
            @foreach (var item in Model) {
                    <tr class="@(item.IsActive ? "" : "table-danger")">
                        <td>
                            @if (item.ClientType == "Persona Natural") { <span class="badge bg-primary">@item.ClientType</span> }
                            else { <span class="badge bg-success">@item.ClientType</span> }
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.DisplayName)</td>
                        <td>@Html.DisplayFor(modelItem => item.Document)</td>
                        <td>@Html.DisplayFor(modelItem => item.Email)</td>
                        <td>@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                            <td>
                                <input type="checkbox" class="form-check-input" disabled @(item.IsActive ? "checked" : "") />
                            </td>
                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.ClientID" class="btn btn-sm btn-warning">Editar</a>
                                <a asp-action="Details" asp-route-id="@item.ClientID" class="btn btn-sm btn-info">Detalles</a>
                                <a asp-action="Delete" asp-route-id="@item.ClientID" class="btn btn-sm btn-danger">Eliminar</a>
                            </td>
                    </tr>
            }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="d-flex justify-content-center align-items-center mt-3">
    @{
        var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
        var nextDisabled = !Model.HasNextPage ? "disabled" : "";
    }
    <a asp-action="Index"
       asp-route-pageNumber="@(Model.PageIndex - 1)"
       asp-route-searchString="@ViewData["CurrentFilter"]"
       asp-route-pageSize="@ViewData["PageSize"]"
       class="btn btn-outline-secondary @prevDisabled">
        Anterior
    </a>
    <span class="mx-3">Página @Model.PageIndex de @Model.TotalPages</span>
    <a asp-action="Index"
       asp-route-pageNumber="@(Model.PageIndex + 1)"
       asp-route-searchString="@ViewData["CurrentFilter"]"
       asp-route-pageSize="@ViewData["PageSize"]"
       class="btn btn-outline-secondary @nextDisabled">
        Siguiente
    </a>
</div>