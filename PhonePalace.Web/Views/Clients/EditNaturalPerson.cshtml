@model PhonePalace.Web.ViewModels.NaturalPersonEditViewModel
@using PhonePalace.Domain.Enums

@{
    ViewData["Title"] = "Editar Cliente: Persona Natural";
}

<h1>@ViewData["Title"]</h1>
<h4>@Model.DisplayName</h4>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="EditNaturalPerson" asp-route-id="@Model.ClientID" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ClientID" />
            @await Html.PartialAsync("_ToggleButton", new PhonePalace.Web.ViewModels.ToggleButtonViewModel { IsChecked = Model.IsActive, Label = "Activo" })

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FirstName" class="form-label">Nombres</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="LastName" class="form-label">Apellidos</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="DocumentType" class="form-label">Tipo de Documento</label>
                    <select asp-for="DocumentType" asp-items="Html.GetEnumSelectList<DocumentType>()" class="form-select"></select>
                    <span asp-validation-for="DocumentType" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="DocumentNumber" class="form-label">Número de Documento <small class="text-muted">(Opcional)</small></label>
                    <input asp-for="DocumentNumber" class="form-control" data-val="false" />
                    <span asp-validation-for="DocumentNumber" class="text-danger"></span>
                </div>
            </div>

            <h5>Información de Contacto y Dirección</h5>
            <hr />
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="form-label">Correo Electrónico <small class="text-muted">(Opcional)</small></label>
                    <input asp-for="Email" type="text" class="form-control" data-val="false" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="PhoneNumber" class="form-label">Teléfono</label>
                    <input asp-for="PhoneNumber" class="form-control" />
                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                </div>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="DepartmentID" class="form-label">Departamento</label>
                    <select asp-for="DepartmentID" id="DepartmentID" class="form-select" asp-items="ViewBag.DepartmentID">
                        <option value="">-- Seleccione Departamento --</option>
                    </select>
                    <span asp-validation-for="DepartmentID" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="MunicipalityID" class="form-label">Municipio</label>
                    <select asp-for="MunicipalityID" id="MunicipalityID" class="form-select" asp-items="ViewBag.MunicipalityID">
                        <option value="">-- Seleccione un departamento primero --</option>
                    </select>
                    <span asp-validation-for="MunicipalityID" class="text-danger"></span>
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="StreetAddress" class="form-label">Dirección</label>
                <input asp-for="StreetAddress" class="form-control" />
                <span asp-validation-for="StreetAddress" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input type="submit" value="Guardar Cambios" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const departmentDropdown = document.getElementById('DepartmentID');
            const municipalityDropdown = document.getElementById('MunicipalityID');

            departmentDropdown.addEventListener('change', function () {
                const departmentId = this.value;
                municipalityDropdown.innerHTML = '<option value="">Cargando...</option>';

                if (departmentId) {
                    fetch(`@Url.Action("GetMunicipalities", "Clients")?departmentId=${departmentId}`)
                        .then(response => response.json())
                        .then(data => {
                            municipalityDropdown.innerHTML = '<option value="">-- Seleccione Municipio --</option>';
                            data.forEach(item => {
                                municipalityDropdown.add(new Option(item.text, item.value));
                            });
                        })
                        .catch(error => {
                            console.error('Error al cargar municipios:', error);
                            municipalityDropdown.innerHTML = '<option value="">Error al cargar</option>';
                        });
                } else {
                    municipalityDropdown.innerHTML = '<option value="">-- Seleccione un departamento --</option>';
                }
            });

            // Forzar la desactivación de la validación del lado del cliente para campos opcionales.
            $('#DocumentNumber').removeAttr('data-val-required');
            $('#Email').removeAttr('data-val-email');

            // Re-parsear el formulario para que jquery-validation reconozca los cambios.
            var form = $('form');
            form.removeData('validator').removeData('unobtrusiveValidation');
            $.validator.unobtrusive.parse(form);
        });
    </script>
}
