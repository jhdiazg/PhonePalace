@model PhonePalace.Web.ViewModels.LoanCreateViewModel

@{
    ViewData["Title"] = "Nuevo Préstamo";
}

<h1>Registrar Nuevo Préstamo</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="ClientID" class="form-label">Cliente</label>
                <select asp-for="ClientID" class="form-control" asp-items="ViewBag.Clients">
                    <option value="">-- Seleccione un Cliente --</option>
                </select>
                <span asp-validation-for="ClientID" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Date" class="form-label">Fecha</label>
                <input asp-for="Date" class="form-control" type="date" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Amount" class="form-label">Monto</label>
                <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Descripción / Nota</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Forma de Desembolso</label>
                <select name="disbursementMethod" id="disbursementMethod" class="form-select" asp-items="ViewBag.PaymentMethods">
                </select>
            </div>

            <div class="mb-3" id="bank-group" style="display:none;">
                <label class="form-label">Banco de Origen</label>
                <select name="bankId" class="form-select" asp-items="ViewBag.Banks">
                    <option value="">-- Seleccione Banco --</option>
                </select>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Crear Préstamo</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            $('#ClientID').select2({ placeholder: "-- Seleccione un Cliente --", width: '100%' });

            function toggleBank() {
                var method = $('#disbursementMethod').val();
                // Mostrar banco si es Transferencia o Cheque (ajustar según enum)
                if (method === 'Transfer') {
                    $('#bank-group').show();
                } else {
                    $('#bank-group').hide();
                }
            }

            $('#disbursementMethod').change(toggleBank);
            toggleBank(); // Run on load

            $('form').on('submit', function(e) {
                var method = $('#disbursementMethod').val();
                var bankId = $('select[name="bankId"]').val();
                if (method === 'Transfer' && !bankId) {
                    e.preventDefault();
                    alert('Debe seleccionar un banco para el desembolso.');
                }
            });
        });
    </script>
}