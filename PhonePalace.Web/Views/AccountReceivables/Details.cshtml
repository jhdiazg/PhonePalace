@model PhonePalace.Domain.Entities.AccountReceivable

@{
    ViewData["Title"] = "Detalle de Cuenta por Cobrar";
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Información de la Deuda</h5>
                <span class="badge @(Model.IsPaid ? "bg-success" : "bg-danger") fs-6">
                    @(Model.IsPaid ? "PAGADO" : "PENDIENTE")
                </span>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Cliente</dt>
                    <dd class="col-sm-8">@Model.Client.DisplayName</dd>

                    <dt class="col-sm-4">Tipo</dt>
                    <dd class="col-sm-8">@Model.Type</dd>

                    <dt class="col-sm-4">Descripción</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4">Fecha Registro</dt>
                    <dd class="col-sm-8">@Model.Date.ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4">Monto Original</dt>
                    <dd class="col-sm-8">@Model.TotalAmount.ToString("C")</dd>

                    <dt class="col-sm-4 text-danger fs-5">Saldo Actual</dt>
                    <dd class="col-sm-8 text-danger fs-5 fw-bold">@Model.Balance.ToString("C")</dd>
                </dl>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">Historial de Abonos</h5>
            </div>
            <div class="card-body">
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Nota</th>
                            <th>Monto</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Payments != null && Model.Payments.Any())
                        {
                            foreach (var pay in Model.Payments.OrderByDescending(p => p.Date))
                            {
                                <tr>
                                    <td>@pay.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@pay.Note</td>
                                    <td class="text-success fw-bold">@pay.Amount.ToString("C")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted">No hay abonos registrados.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        @if (!Model.IsPaid)
        {
            <div class="card shadow-sm border-success mb-3">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-money-bill-wave"></i> Registrar Abono</h5>
                </div>
                <div class="card-body">
                    <form asp-action="AddPayment" method="post">
                        <input type="hidden" name="id" value="@Model.AccountReceivableID" />
                        
                        <div class="form-group mb-3">
                            <label class="form-label">Monto a Abonar</label>
                            <input type="number" name="amount" class="form-control" step="0.01" max="@Model.Balance" required />
                            <small class="text-muted">Máximo: @Model.Balance.ToString("C")</small>
                        </div>

                        <div class="form-group mb-3">
                            <label class="form-label">Nota / Referencia</label>
                            <input type="text" name="note" class="form-control" placeholder="Ej. Pago en efectivo" />
                        </div>

                        <button type="submit" class="btn btn-success w-100">Registrar Ingreso</button>
                    </form>
                </div>
            </div>
        }

        @if (!(Model.Payments?.Any() ?? false))
        {
            <div class="card shadow-sm border-danger">
                <div class="card-body">
                    <h6 class="text-danger">Zona de Peligro</h6>
                    <p class="small">Si este registro fue un error y no tiene abonos, puede eliminarlo.</p>
                    <form asp-action="Delete" asp-route-id="@Model.AccountReceivableID" method="post" onsubmit="return confirm('¿Está seguro de eliminar esta cuenta por cobrar?');">
                        <button type="submit" class="btn btn-outline-danger w-100">Eliminar Registro</button>
                    </form>
                </div>
            </div>
        }
        
        <div class="mt-3">
            <a asp-action="Index" class="btn btn-secondary w-100">Volver al Listado</a>
        </div>
    </div>
</div>
