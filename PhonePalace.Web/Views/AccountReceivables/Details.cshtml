@model PhonePalace.Domain.Entities.AccountReceivable
@using PhonePalace.Web.Helpers

@{
    ViewData["Title"] = "Detalles de Cuenta por Cobrar";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0">Información de la Cuenta</h5>
            </div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Cliente</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Client.DisplayName)</dd>

                    <dt class="col-sm-4">Fecha</dt>
                    <dd class="col-sm-8">@Model.Date.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-sm-4">Tipo</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Type)</dd>

                    <dt class="col-sm-4">Descripción</dt>
                    <dd class="col-sm-8">@Html.DisplayFor(model => model.Description)</dd>

                    <dt class="col-sm-4">Monto Total</dt>
                    <dd class="col-sm-8">@Model.TotalAmount.ToString("C")</dd>

                    <dt class="col-sm-4">Saldo Pendiente</dt>
                    <dd class="col-sm-8 text-danger fw-bold">@Model.Balance.ToString("C")</dd>
                    
                    <dt class="col-sm-4">Estado</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsPaid)
                        {
                            <span class="badge bg-success">Pagado</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Pendiente</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        @if (!Model.IsPaid)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Registrar Abono</h5>
                </div>
                <div class="card-body">
                    <form asp-action="AddPayment" method="post">
                        <input type="hidden" name="id" value="@Model.AccountReceivableID" />
                        
                        <div class="mb-3">
                            <label for="amount" class="form-label">Monto a Abonar</label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input type="number" id="amount" name="amount" class="form-control" step="0.01" min="0.01" max="@Model.Balance" required />
                            </div>
                            <div class="form-text">Saldo actual: @Model.Balance.ToString("C")</div>
                        </div>

                        <div class="mb-3">
                            <label for="paymentMethod" class="form-label">Forma de Pago</label>
                            <select id="paymentMethod" name="paymentMethod" class="form-select" asp-items="ViewBag.PaymentMethods" required>
                                <option value="">-- Seleccione --</option>
                            </select>
                            <div class="form-text">Solo los pagos en <strong>Efectivo</strong> afectarán la caja.</div>
                        </div>

                        <div class="mb-3">
                            <label for="note" class="form-label">Nota (Opcional)</label>
                            <input type="text" id="note" name="note" class="form-control" placeholder="Referencia, detalle..." />
                        </div>

                        <button type="submit" class="btn btn-success w-100">Registrar Pago</button>
                    </form>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-success">
                <h4 class="alert-heading">¡Pagado!</h4>
                <p>Esta cuenta ha sido pagada en su totalidad.</p>
            </div>
        }
    </div>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header">
        <h5 class="mb-0">Historial de Pagos</h5>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Monto</th>
                        <th>Detalle</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Payments != null && Model.Payments.Any())
                    {
                        foreach (var item in Model.Payments.OrderByDescending(p => p.Date))
                        {
                            <tr>
                                <td>@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.Amount.ToString("C")</td>
                                <td>@item.Note</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted">No hay pagos registrados.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Volver a la Lista</a>
</div>