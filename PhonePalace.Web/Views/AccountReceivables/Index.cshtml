@model IEnumerable<PhonePalace.Domain.Entities.AccountReceivable>

@{
    ViewData["Title"] = "Cuentas por Cobrar";
}

<h1>@ViewData["Title"]</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-hand-holding-usd"></i> Nuevo Préstamo
        </a>
    </div>
    <div class="col-md-6 text-end">
        <h4 class="text-danger">Total Pendiente: @(((decimal)ViewBag.TotalReceivable).ToString("C"))</h4>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Cliente</label>
                <input type="text" name="clientName" value="@ViewBag.ClientName" class="form-control" placeholder="Buscar..." />
            </div>
            <div class="col-md-3">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" name="showPaid" value="true" id="showPaid" @(ViewBag.ShowPaid ? "checked" : "")>
                    <label class="form-check-label" for="showPaid">
                        Mostrar Pagadas
                    </label>
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Tipo</th>
                <th>Descripción</th>
                <th>Monto Original</th>
                <th>Saldo Pendiente</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                    <td>@item.Client.DisplayName</td>
                    <td>
                        <span class="badge @(item.Type == "Venta" ? "bg-info" : "bg-warning text-dark")">@item.Type</span>
                    </td>
                    <td>@item.Description</td>
                    <td>@item.TotalAmount.ToString("C")</td>
                    <td class="fw-bold text-danger">@item.Balance.ToString("C")</td>
                    <td>
                        @if (item.IsPaid)
                        {
                            <span class="badge bg-success">Pagado</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Pendiente</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.AccountReceivableID" class="btn btn-sm btn-primary">
                            <i class="fas fa-eye"></i> Detalles / Abonar
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
