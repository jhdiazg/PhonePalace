@model PhonePalace.Web.Helpers.PaginatedList<PhonePalace.Domain.Entities.AccountReceivable>
@using PhonePalace.Web.Helpers

@{
    ViewData["Title"] = "Cuentas por Cobrar";
}

<h1>@ViewData["Title"]</h1>

<div class="row mb-3">
    <div class="col-md-6">
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-hand-holding-usd"></i> Nuevo Préstamo
        </a>
    </div>
    <div class="col-md-6 text-end">
        <h4 class="text-danger">Total Pendiente: @(((decimal)ViewBag.TotalReceivable).ToString("C"))</h4>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end" id="arFilterForm">
            <div class="col-md-2">
                <label class="form-label">Fecha Inicio</label>
                <input type="date" name="startDate" value="@ViewBag.StartDate" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Fecha Fin</label>
                <input type="date" name="endDate" value="@ViewBag.EndDate" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Cliente</label>
                <input type="text" name="clientName" value="@ViewBag.ClientName" class="form-control" placeholder="Buscar..." />
            </div>
            <div class="col-md-2">
                <label class="form-label">Tipo</label>
                <select name="type" class="form-select" asp-items="ViewBag.TypeList">
                    <option value="">-- Todos --</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Estado</label>
                <select name="status" class="form-select" asp-items="ViewBag.StatusList"></select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-secondary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Fecha</th>
                <th>Cliente</th>
                <th>Tipo</th>
                <th>Descripción</th>
                <th>Monto Original</th>
                <th>Saldo Pendiente</th>
                <th>Días Mora</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                    <td>@item.Client.DisplayName</td>
                    <td>
                        <span class="badge @(item.Type == "Venta" ? "bg-info" : "bg-warning text-dark")">@item.Type</span>
                    </td>
                    <td>@item.Description</td>
                    <td>@item.TotalAmount.ToString("C")</td>
                    <td class="fw-bold text-danger">@item.Balance.ToString("C")</td>
                    <td>
                        @if (!item.IsPaid)
                        {
                            var days = (DateTime.Now.Date - item.Date.Date).Days;
                            <span class="@(days > 30 ? "text-danger fw-bold" : "")">@days días</span>
                        }
                        else
                        {
                            <span>-</span>
                        }
                    </td>
                    <td>
                        @if (item.IsPaid)
                        {
                            <span class="badge bg-success">Pagado</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Pendiente</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.AccountReceivableID" class="btn btn-sm btn-primary">
                            <i class="fas fa-eye"></i> Detalles / Abonar
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@{
    var prevDisabled = !Model.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.HasNextPage ? "disabled" : "";
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <div>
        <a asp-action="Index"
           asp-route-pageNumber="@(Model.PageIndex - 1)"
           asp-route-clientName="@ViewBag.ClientName"
           asp-route-status="@ViewBag.CurrentStatus"
           asp-route-type="@ViewBag.CurrentType"
           asp-route-startDate="@ViewBag.StartDate"
           asp-route-endDate="@ViewBag.EndDate"
           class="btn btn-outline-secondary @prevDisabled">Anterior</a>
        <a asp-action="Index"
           asp-route-pageNumber="@(Model.PageIndex + 1)"
           asp-route-clientName="@ViewBag.ClientName"
           asp-route-status="@ViewBag.CurrentStatus"
           asp-route-type="@ViewBag.CurrentType"
           asp-route-startDate="@ViewBag.StartDate"
           asp-route-endDate="@ViewBag.EndDate"
           class="btn btn-outline-secondary @nextDisabled">Siguiente</a>
    </div>
    <div class="text-muted">
        Página @Model.PageIndex de @Model.TotalPages
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#arFilterForm').on('submit', function (e) {
                var startDate = $('input[name="startDate"]').val();
                var endDate = $('input[name="endDate"]').val();

                if (startDate && endDate) {
                    if (new Date(startDate) > new Date(endDate)) {
                        e.preventDefault();
                        alert('La fecha de inicio no puede ser mayor a la fecha de fin.');
                    }
                }
            });
        });
    </script>
}
