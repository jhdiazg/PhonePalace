@model PhonePalace.Web.ViewModels.CashCloseViewModel

@{
    ViewData["Title"] = "Cerrar Caja";
}

<h1>Cerrar Caja</h1>

<form asp-action="Close" method="post">
    <div class="form-group">
        <label asp-for="ClosingAmount"></label>
        <input asp-for="ClosingAmount" class="form-control" type="number" step="0.01" min="0" />
        <span asp-validation-for="ClosingAmount" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-warning">Cerrar Caja</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>