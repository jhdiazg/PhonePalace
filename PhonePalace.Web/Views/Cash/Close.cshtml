@model PhonePalace.Web.ViewModels.CashCloseViewModel

@{
    ViewData["Title"] = "Cerrar Caja";
}

<h1>@ViewData["Title"]</h1>
<p class="text-muted">Verifique el dinero físico en caja antes de cerrar.</p>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="alert alert-info">
                    <strong>Saldo en Sistema:</strong> @Model.SystemBalance.ToString("C")
                </div>

                <form asp-action="Close" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input type="hidden" asp-for="SystemBalance" />

                    <div class="mb-3">
                        <label asp-for="ClosingAmount" class="form-label"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="ClosingAmount" class="form-control" type="number" step="0.01" autofocus />
                        </div>
                        <span asp-validation-for="ClosingAmount" class="text-danger"></span>
                        <div class="form-text">Ingrese la cantidad total de dinero contada físicamente en la caja.</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Observation" class="form-label">Observaciones (Opcional)</label>
                        <textarea asp-for="Observation" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Observation" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg">Cerrar Caja</button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>