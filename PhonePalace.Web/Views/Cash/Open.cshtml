@model PhonePalace.Web.ViewModels.CashOpenViewModel

@{
    ViewData["Title"] = "Abrir Caja";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="bi bi-cash-coin me-2"></i>@ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Open">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="mb-3">
                            <label asp-for="OpeningBalance" class="form-label fw-bold">Monto de Apertura</label>
                            
                            <div class="d-flex align-items-center flex-wrap">
                                <!-- Caja de texto pequeña con formato moneda -->
                                <div class="input-group" style="width: 200px;">
                                    <span class="input-group-text">$</span>
                                    <input asp-for="OpeningBalance" class="form-control text-end" placeholder="0" type="number" step="1" min="0" />
                                </div>
                                
                                <!-- Botones a la derecha, separados del input y entre sí -->
                                <div class="d-flex gap-2 ms-3">
                                    <button type="submit" class="btn btn-success">
                                        <i class="bi bi-check-lg me-1"></i> Abrir Caja
                                    </button>
                                    <a asp-action="Index" class="btn btn-secondary">
                                        <i class="bi bi-x-lg me-1"></i> Cancelar
                                    </a>
                                </div>
                            </div>
                            <span asp-validation-for="OpeningBalance" class="text-danger"></span>
                            <div class="form-text text-muted">Ingrese el monto inicial en efectivo (sin decimales).</div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}