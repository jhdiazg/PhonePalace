@model PhonePalace.Web.ViewModels.CashOpenViewModel

@{
    ViewData["Title"] = "Abrir Caja";
}

<h1>Abrir Caja</h1>

<form asp-action="Open" method="post">
    <div class="form-group">
        <label asp-for="OpeningAmount"></label>
        <input asp-for="OpeningAmount" class="form-control" type="number" step="0.01" min="0" />
        <span asp-validation-for="OpeningAmount" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Abrir Caja</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>