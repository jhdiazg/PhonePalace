@model PhonePalace.Domain.Entities.Return

@{
    ViewData["Title"] = "Detalle de Devolución";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Devolución #@Model.ReturnID</h1>
    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver al Historial</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0">Información General</h5>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Fecha:</dt>
                    <dd class="col-sm-8">@Model.Date.ToString("g")</dd>

                    <dt class="col-sm-4">Cliente:</dt>
                    <dd class="col-sm-8">@Model.Client.DisplayName</dd>

                    <dt class="col-sm-4">Venta Origen:</dt>
                    <dd class="col-sm-8">
                        <a asp-controller="Sales" asp-action="Details" asp-route-id="@Model.SaleID">Venta #@Model.SaleID</a>
                    </dd>

                    <dt class="col-sm-4">Total Abonado:</dt>
                    <dd class="col-sm-8 fw-bold text-success fs-5">@Model.TotalAmount.ToString("C")</dd>
                </dl>
            </div>
        </div>
    </div>
    
    <div class="col-md-6">
        <div class="alert alert-info h-100">
            <h5 class="alert-heading"><i class="bi bi-wallet2"></i> Impacto en Saldo</h5>
            <p>
                Esta devolución generó un abono inmediato de <strong>@Model.TotalAmount.ToString("C")</strong> al saldo a favor del cliente.
            </p>
            <hr>
            <p class="mb-0">
                Saldo actual del cliente: <strong>@Model.Client.Balance.ToString("C")</strong>
            </p>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header">
        <h5 class="mb-0">Productos Devueltos (Reingresados al Inventario)</h5>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped mb-0">
            <thead>
                <tr>
                    <th>Producto</th>
                    <th class="text-center">Cantidad</th>
                    <th class="text-end">Valor Unitario</th>
                    <th class="text-end">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var detail in Model.Details)
                {
                    <tr>
                        <td>@detail.Product.Name</td>
                        <td class="text-center">@detail.Quantity</td>
                        <td class="text-end">@detail.UnitPrice.ToString("C")</td>
                        <td class="text-end">@((detail.Quantity * detail.UnitPrice).ToString("C"))</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>