@model PhonePalace.Web.ViewModels.MonthlyBalanceViewModel

@{
    ViewData["Title"] = "Balance Mensual";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Balance Mensual - @Model.Year</h1>
        <form asp-action="MonthlyBalance" method="get" class="d-flex align-items-center">
            <label for="year" class="me-2 fw-bold">Año:</label>
            <input type="number" class="form-control me-2" id="year" name="year" value="@Model.Year" style="width: 100px;">
            <button type="submit" class="btn btn-primary">Generar</button>
        </form>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped mb-0 text-end">
                    <thead class="table-dark text-center align-middle">
                        <tr>
                            <th>Mes</th>
                            <th>Ventas</th>
                            <th>IVA Ventas</th>
                            <th>Costo Aprox.</th>
                            <th>Utilidad Bruta</th>
                            <th class="text-success">Otros Ingresos</th>
                            <th>Gastos Fijos</th>
                            <th>Gastos Local</th>
                            <th>Pagos a Prov.</th>
                            <th>IVA Compras</th>
                            <th>Créditos Otorgados</th>
                            <th class="bg-info text-dark">Activos (Valor)</th>
                            <th>Utilidad Neta</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="text-start fw-bold">@item.MonthName</td>
                                <td>@item.Sales.ToString("C0")</td>
                                <td class="text-muted"><small>@item.SalesVAT.ToString("C0")</small></td>
                                <td class="text-muted"><small>@item.Cost.ToString("C0")</small></td>
                                <td class="fw-bold text-primary">@((item.Sales - item.Cost).ToString("C0"))</td>
                                <td class="text-success">
                                    @if (item.OtherIncome > 0)
                                    {
                                        <a href="#" class="text-success text-decoration-none fw-bold" onclick="showOtherIncomeDetails(@item.Month, @Model.Year); return false;" title="Ver detalle">
                                            @item.OtherIncome.ToString("C0")
                                        </a>
                                    }
                                    else
                                    {
                                        @item.OtherIncome.ToString("C0")
                                    }
                                </td>
                                <td>@item.FixedExpenses.ToString("C0")</td>
                                <td>@item.LocalExpenses.ToString("C0")</td>
                                <td>@item.Purchases.ToString("C0")</td>
                                <td class="text-muted"><small>@item.PurchaseVAT.ToString("C0")</small></td>
                                <td>@item.AccountsReceivable.ToString("C0")</td>
                                <td class="table-info fw-bold">@item.AssetsValue.ToString("C0")</td>
                                <td class="@(item.Profit >= 0 ? "text-success" : "text-danger") fw-bold fs-6">@item.Profit.ToString("C0")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-secondary fw-bold">
                        <tr>
                            <td class="text-start">TOTALES / FINAL</td>
                            <td>@Model.Totals.Sales.ToString("C0")</td>
                            <td>@Model.Totals.SalesVAT.ToString("C0")</td>
                            <td>@Model.Totals.Cost.ToString("C0")</td>
                            <td>@((Model.Totals.Sales - Model.Totals.Cost).ToString("C0"))</td>
                            <td class="text-success">@Model.Totals.OtherIncome.ToString("C0")</td>
                            <td>@Model.Totals.FixedExpenses.ToString("C0")</td>
                            <td>@Model.Totals.LocalExpenses.ToString("C0")</td>
                            <td>@Model.Totals.Purchases.ToString("C0")</td>
                            <td>@Model.Totals.PurchaseVAT.ToString("C0")</td>
                            <td>@Model.Totals.AccountsReceivable.ToString("C0")</td>
                            <td class="table-info">@Model.Totals.AssetsValue.ToString("C0")</td>
                            <td class="@(Model.Totals.Profit >= 0 ? "text-success" : "text-danger") fs-5">@Model.Totals.Profit.ToString("C0")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Detalle -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title">Detalle de Otros Ingresos</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table table-sm table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Fuente</th>
                                <th>Descripción</th>
                                <th class="text-end">Monto</th>
                            </tr>
                        </thead>
                        <tbody id="modalTableBody">
                            <!-- Contenido dinámico -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showOtherIncomeDetails(month, year) {
            var modal = new bootstrap.Modal(document.getElementById('detailsModal'));
            var tbody = document.getElementById('modalTableBody');
            tbody.innerHTML = '<tr><td colspan="4" class="text-center py-3"><div class="spinner-border text-primary" role="status"></div><br>Cargando detalles...</td></tr>';
            modal.show();

            fetch(`/Reportes/DetalleOtrosIngresos?month=${month}&year=${year}`)
                .then(response => response.json())
                .then(data => {
                    tbody.innerHTML = '';
                    if (data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">No se encontraron detalles.</td></tr>';
                        return;
                    }
                    
                    let total = 0;
                    const formatter = new Intl.NumberFormat('es-CO', { style: 'currency', currency: 'COP', minimumFractionDigits: 0 });

                    data.forEach(item => {
                        total += item.Amount;
                        let row = `<tr>
                            <td>${item.Date}</td>
                            <td><span class="badge bg-info text-dark">${item.Source}</span></td>
                            <td>${item.Description || '-'}</td>
                            <td class="text-end fw-bold text-success">${formatter.format(item.Amount)}</td>
                        </tr>`;
                        tbody.innerHTML += row;
                    });
                    
                    // Fila de Total
                    tbody.innerHTML += `<tr class="table-active border-top border-2">
                        <td colspan="3" class="text-end fw-bold">TOTAL</td>
                        <td class="text-end fw-bold text-success fs-6">${formatter.format(total)}</td>
                    </tr>`;
                })
                .catch(error => {
                    console.error('Error:', error);
                    tbody.innerHTML = '<tr><td colspan="4" class="text-center text-danger">Error al cargar los datos. Intente nuevamente.</td></tr>';
                });
        }
    </script>
}