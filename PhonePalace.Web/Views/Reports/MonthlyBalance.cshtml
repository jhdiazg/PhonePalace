@model PhonePalace.Web.ViewModels.MonthlyBalanceViewModel

@{
    ViewData["Title"] = "Balance Mensual";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Balance Mensual - @Model.Year</h1>
        <form asp-action="MonthlyBalance" method="get" class="d-flex align-items-center">
            <label for="year" class="me-2 fw-bold">Año:</label>
            <input type="number" class="form-control me-2" id="year" name="year" value="@Model.Year" style="width: 100px;">
            <button type="submit" class="btn btn-primary">Generar</button>
        </form>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered table-hover table-striped mb-0 text-end">
                    <thead class="table-dark text-center align-middle">
                        <tr>
                            <th>Mes</th>
                            <th>Ventas</th>
                            <th>IVA Ventas</th>
                            <th>Costo Aprox.</th>
                            <th>Utilidad Bruta</th>
                            <th>Gastos Fijos</th>
                            <th>Gastos Local</th>
                            <th>Compras</th>
                            <th>IVA Compras</th>
                            <th>CxC (Créditos)</th>
                            <th class="bg-info text-dark">Activos (Valor)</th>
                            <th>Utilidad Neta</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="text-start fw-bold">@item.MonthName</td>
                                <td>@item.Sales.ToString("C0")</td>
                                <td class="text-muted"><small>@item.SalesVAT.ToString("C0")</small></td>
                                <td class="text-muted"><small>@item.Cost.ToString("C0")</small></td>
                                <td class="fw-bold text-primary">@((item.Sales - item.Cost).ToString("C0"))</td>
                                <td>@item.FixedExpenses.ToString("C0")</td>
                                <td>@item.LocalExpenses.ToString("C0")</td>
                                <td>@item.Purchases.ToString("C0")</td>
                                <td class="text-muted"><small>@item.PurchaseVAT.ToString("C0")</small></td>
                                <td>@item.AccountsReceivable.ToString("C0")</td>
                                <td class="table-info fw-bold">@item.AssetsValue.ToString("C0")</td>
                                <td class="@(item.Profit >= 0 ? "text-success" : "text-danger") fw-bold fs-6">@item.Profit.ToString("C0")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-secondary fw-bold">
                        <tr>
                            <td class="text-start">TOTALES / FINAL</td>
                            <td>@Model.Totals.Sales.ToString("C0")</td>
                            <td>@Model.Totals.SalesVAT.ToString("C0")</td>
                            <td>@Model.Totals.Cost.ToString("C0")</td>
                            <td>@((Model.Totals.Sales - Model.Totals.Cost).ToString("C0"))</td>
                            <td>@Model.Totals.FixedExpenses.ToString("C0")</td>
                            <td>@Model.Totals.LocalExpenses.ToString("C0")</td>
                            <td>@Model.Totals.Purchases.ToString("C0")</td>
                            <td>@Model.Totals.PurchaseVAT.ToString("C0")</td>
                            <td>@Model.Totals.AccountsReceivable.ToString("C0")</td>
                            <td class="table-info">@Model.Totals.AssetsValue.ToString("C0")</td>
                            <td class="@(Model.Totals.Profit >= 0 ? "text-success" : "text-danger") fs-5">@Model.Totals.Profit.ToString("C0")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>