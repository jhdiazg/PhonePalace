@model PhonePalace.Web.ViewModels.SalesReportViewModel
@using PhonePalace.Web.Helpers

@{
    ViewData["Title"] = "Reporte de Ventas por Forma de Pago";
    decimal totalCustomerBalance = ViewData["TotalCustomerBalance"] as decimal? ?? 0;
    decimal totalRealIncome = ViewData["TotalRealIncome"] as decimal? ?? 0;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>@ViewData["Title"]</h1>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Fecha Inicio</label>
                <input type="date" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Fecha Fin</label>
                <input type="date" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")" class="form-control" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Método de Pago</label>
                <select name="selectedPaymentMethod" asp-items="Model.PaymentMethods" class="form-select">
                    <option value="">-- Todos --</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">Filtrar</button>
            </div>
        </form>
    </div>
</div>

<!-- Sección de Totales Destacados -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary h-100">
            <div class="card-body text-center">
                <h5 class="card-title">Total Ventas</h5>
                <p class="card-text display-6">@Model.TotalSales.ToString("C")</p>
                <small>Volumen total de ventas</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success h-100">
            <div class="card-body text-center">
                <h5 class="card-title">Ingreso Real (Caja/Bancos)</h5>
                <p class="card-text display-6">@totalRealIncome.ToString("C")</p>
                <small>Efectivo, Tarjetas, Transferencias</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-dark bg-warning h-100">
            <div class="card-body text-center">
                <h5 class="card-title">Pagado con Saldo a Favor</h5>
                <p class="card-text display-6">@totalCustomerBalance.ToString("C")</p>
                <small>Uso de billetera de clientes (Devoluciones/Anticipos)</small>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-dark bg-light border-warning h-100">
            <div class="card-body text-center">
                <h5 class="card-title text-warning fw-bold">Devoluciones</h5>
                <p class="card-text display-6">@(((decimal)(ViewData["TotalReturns"] ?? 0)).ToString("C"))</p>
                <small class="text-muted">Informativo (No resta)</small>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0">Resumen por Método</h5>
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var item in Model.Summary)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        @item.PaymentMethod
                        <span class="badge bg-secondary rounded-pill">@item.TotalAmount.ToString("C")</span>
                    </li>
                }
            </ul>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">Detalle de Pagos</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th>Cliente</th>
                                <th>Método</th>
                                <th>Referencia</th>
                                <th class="text-end">Monto</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Details!)
                            {
                                <tr>
                                    <td>@item.Date.ToString("g")</td>
                                    <td>@item.ClientName</td>
                                    <td>
                                        @item.PaymentMethod
                                        @if(item.PaymentMethod.Contains("Saldo") || item.PaymentMethod == "CustomerBalance")
                                        {
                                            <i class="bi bi-wallet2 text-warning ms-1" title="Saldo a Favor"></i>
                                        }
                                    </td>
                                    <td>@item.Reference</td>
                                    <td class="text-end">@item.Amount.ToString("C")</td>
                                    <td class="text-end">
                                        @if (item.SaleId.HasValue)
                                        {
                                            <a asp-controller="Sales" asp-action="Details" asp-route-id="@item.SaleId" class="btn btn-sm btn-outline-info" title="Ver Venta">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Paginación -->
                @if (Model.Details.TotalPages > 1)
                {
                    <nav aria-label="Page navigation" class="mt-3">
                        <ul class="pagination justify-content-center">
                            <li class="page-item @(Model.Details.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link" asp-action="SalesByPaymentMethod" asp-route-pageNumber="@(Model.Details.PageIndex - 1)" asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")" asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")" asp-route-selectedPaymentMethod="@Model.SelectedPaymentMethod">Anterior</a>
                            </li>
                            <li class="page-item @(Model.Details.HasNextPage ? "" : "disabled")">
                                <a class="page-link" asp-action="SalesByPaymentMethod" asp-route-pageNumber="@(Model.Details.PageIndex + 1)" asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")" asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")" asp-route-selectedPaymentMethod="@Model.SelectedPaymentMethod">Siguiente</a>
                            </li>
                        </ul>
                    </nav>
                }
            </div>
        </div>
    </div>
</div>