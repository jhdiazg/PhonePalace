@model PhonePalace.Web.ViewModels.SalesReportViewModel
@{
    ViewData["Title"] = "Ventas por Forma de Pago";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-credit-card-2-front me-2"></i>@ViewData["Title"]</h2>
    </div>

    @* Bloque de Alertas para validaciones de fechas *@
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle-fill me-2"></i> @TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Warning"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Filtros</h5>
        </div>
        <div class="card-body">
            <form asp-action="SalesByPaymentMethod" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label for="startDate" class="form-label">Fecha Inicial</label>
                    <input type="date" class="form-control" id="startDate" name="startDate" value="@Model.StartDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <label for="endDate" class="form-label">Fecha Final</label>
                    <input type="date" class="form-control" id="endDate" name="endDate" value="@Model.EndDate.ToString("yyyy-MM-dd")">
                </div>
                <div class="col-md-3">
                    <label for="selectedPaymentMethod" class="form-label">Forma de Pago</label>
                    <select class="form-select" id="selectedPaymentMethod" name="selectedPaymentMethod" asp-items="Model.PaymentMethods">
                        <option value="">-- Todas --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary w-100"><i class="bi bi-filter"></i> Filtrar</button>
                        <a asp-action="SalesByPaymentMethod" class="btn btn-outline-secondary" title="Limpiar Filtros"><i class="bi bi-x-lg"></i> Limpiar</a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white h-100">
                <div class="card-body text-center">
                    <h6 class="card-title">Total Ventas</h6>
                    <h3 class="display-6 fw-bold">@Model.TotalSales.ToString("C0")</h3>
                    <p class="card-text"><small>Periodo Seleccionado</small></p>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card h-100">
                <div class="card-header">
                    Resumen por Método
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Método</th>
                                    <th class="text-center">Transacciones</th>
                                    <th class="text-end">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Summary)
                                {
                                    <tr>
                                        <td>@item.PaymentMethod</td>
                                        <td class="text-center">@item.Count</td>
                                        <td class="text-end">@item.TotalAmount.ToString("C0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header">
            <h5 class="mb-0">Detalle de Transacciones</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha</th>
                            <th>Factura</th>
                            <th>Cliente</th>
                            <th>Método</th>
                            <th>Referencia</th>
                            <th class="text-end">Monto</th>
                            <th class="text-center">Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Details!.Any())
                        {
                            foreach (var item in Model.Details!)
                            {
                                <tr>
                                    <td>@item.Date.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>#@item.InvoiceId</td>
                                    <td>@item.ClientName</td>
                                    <td><span class="badge bg-secondary">@item.PaymentMethod</span></td>
                                    <td>@item.Reference</td>
                                    <td class="text-end">@item.Amount.ToString("C0")</td>
                                    <td class="text-center">
                                        @if (item.SaleId.HasValue)
                                        {
                                            <a asp-controller="Sales" asp-action="Details" asp-route-id="@item.SaleId" class="btn btn-sm btn-info text-white" title="Ver Venta">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">
                                    No se encontraron registros para los filtros seleccionados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item @(Model.Details!.HasPreviousPage ? "" : "disabled")">
                        <a class="page-link" asp-action="SalesByPaymentMethod" 
                           asp-route-pageNumber="@(Model.Details.PageIndex - 1)"
                           asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
                           asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")"
                           asp-route-selectedPaymentMethod="@Model.SelectedPaymentMethod">
                           Anterior
                        </a>
                    </li>
                    <li class="page-item disabled">
                        <span class="page-link">Página @Model.Details.PageIndex de @Model.Details.TotalPages</span>
                    </li>
                    <li class="page-item @(Model.Details.HasNextPage ? "" : "disabled")">
                        <a class="page-link" asp-action="SalesByPaymentMethod" 
                           asp-route-pageNumber="@(Model.Details.PageIndex + 1)"
                           asp-route-startDate="@Model.StartDate.ToString("yyyy-MM-dd")"
                           asp-route-endDate="@Model.EndDate.ToString("yyyy-MM-dd")"
                           asp-route-selectedPaymentMethod="@Model.SelectedPaymentMethod">
                           Siguiente
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>