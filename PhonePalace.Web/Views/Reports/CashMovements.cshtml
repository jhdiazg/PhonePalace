@model PhonePalace.Web.ViewModels.CashMovementReportViewModel
@using PhonePalace.Domain.Enums
@using PhonePalace.Web.Helpers

@{
    ViewData["Title"] = "Reporte Diario de Caja";
    var userNames = ViewBag.UserNames as Dictionary<string, string>;
}

<h1>@ViewData["Title"]</h1>

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form asp-action="CashMovements" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label asp-for="ReportDate" class="form-label">Seleccione la Fecha</label>
                <input asp-for="ReportDate" type="date" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label">Mostrar</label>
                <select name="pageSize" class="form-select" onchange="this.form.submit()">
                    @{ int pageSize = (int)(ViewData["PageSize"] ?? 20); }
                    <option value="20" selected="@(pageSize == 20)">20</option>
                    <option value="50" selected="@(pageSize == 50)">50</option>
                    <option value="100" selected="@(pageSize == 100)">100</option>
                    <option value="200" selected="@(pageSize == 200)">200</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">Generar Reporte</button>
            </div>
        </form>
    </div>
</div>

@if (Model.IsCashRegisterFound)
{
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0">Movimientos del @Model.ReportDate.ToString("dd/MM/yyyy")</h5>
        </div>
        <div class="card-body">
            <div class="row text-center mb-4">
                <div class="col">
                    <div class="stat-card border-start border-4 border-secondary p-3">
                        <h6 class="text-muted">Saldo Apertura</h6>
                        <h4 class="fw-bold">@Model.OpeningBalance.ToString("C")</h4>
                    </div>
                </div>
                <div class="col">
                    <div class="stat-card border-start border-4 border-success p-3">
                        <h6 class="text-muted">Total Ingresos</h6>
                        <h4 class="fw-bold text-success">@((Model.TotalIncome - Model.OpeningBalance).ToString("C"))</h4>
                    </div>
                </div>
                <div class="col">
                    <div class="stat-card border-start border-4 border-danger p-3">
                        <h6 class="text-muted">Total Egresos</h6>
                        <h4 class="fw-bold text-danger">@Model.TotalExpenses.ToString("C")</h4>
                    </div>
                </div>
                <div class="col">
                    <div class="stat-card border-start border-4 border-primary p-3">
                        <h6 class="text-muted">Saldo Esperado en Caja</h6>
                        <h4 class="fw-bold text-primary">@Model.ExpectedBalance.ToString("C")</h4>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Fecha y Hora</th>
                            <th>Tipo</th>
                            <th>Descripción</th>
                            <th>Usuario</th>
                            <th class="text-end">Monto</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Movements)
                        {
                            var amountClass = item.MovementType == CashMovementType.Income || item.MovementType == CashMovementType.Opening ? "text-success" : "text-danger";
                            var amountPrefix = item.MovementType == CashMovementType.Income || item.MovementType == CashMovementType.Opening ? "+" : "-";
                            <tr>
                                <td>@item.MovementDate.ToString("g")</td>
                                <td>
                                    <span class="badge @(item.MovementType == CashMovementType.Opening ? "bg-info text-dark" : item.MovementType == CashMovementType.Closing ? "bg-dark" : item.MovementType == CashMovementType.Income ? "bg-success-light text-success" : "bg-danger-light text-danger")">
                                        @EnumHelper.GetDisplayName(item.MovementType)
                                    </span>
                                </td>
                                <td>@item.Description</td>
                                <td>@(item.UserId != null && userNames != null && userNames.ContainsKey(item.UserId) ? userNames[item.UserId] : (item.UserId ?? "N/A"))</td>
                                <td class="text-end fw-bold @amountClass">
                                    @if(item.MovementType != CashMovementType.Opening && item.MovementType != CashMovementType.Closing)
                                    {
                                        <span>@amountPrefix</span>
                                    }
                                    @item.Amount.ToString("C")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        @{
            var paginated = ViewData["PaginatedMovements"] as PaginatedList<CashMovement>;
        }
        @if (paginated != null && paginated.TotalPages > 1)
        {
            <div class="card-footer">
                @{
                    var prevDisabled = !paginated.HasPreviousPage ? "disabled" : "";
                    var nextDisabled = !paginated.HasNextPage ? "disabled" : "";
                }
                <div class="d-flex justify-content-center align-items-center">
                    <a asp-action="CashMovements"
                       asp-route-pageNumber="@(paginated.PageIndex - 1)"
                       asp-route-reportDate="@Model.ReportDate.ToString("yyyy-MM-dd")"
                       asp-route-pageSize="@ViewData["PageSize"]"
                       class="btn btn-secondary @prevDisabled">
                        Anterior
                    </a>
                    <span class="mx-3">Página @paginated.PageIndex de @paginated.TotalPages</span>
                    <a asp-action="CashMovements"
                       asp-route-pageNumber="@(paginated.PageIndex + 1)"
                       asp-route-reportDate="@Model.ReportDate.ToString("yyyy-MM-dd")"
                       asp-route-pageSize="@ViewData["PageSize"]"
                       class="btn btn-secondary @nextDisabled">
                        Siguiente
                    </a>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info text-center">
        <i class="bi bi-info-circle-fill me-2"></i> No se encontró ninguna caja abierta para la fecha seleccionada. Por favor, seleccione otra fecha.
    </div>
}