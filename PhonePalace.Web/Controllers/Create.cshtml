@model PhonePalace.Domain.Entities.Asset
@using PhonePalace.Domain.Enums

@{
    ViewData["Title"] = "Registrar Activo";
}

<h1>Registrar Nuevo Activo</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Nombre del Activo</label>
                <input asp-for="Name" class="form-control" placeholder="Ej. Vitrina Exhibidora, Computador Portátil" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Descripción</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="SerialNumber" class="form-label">Serial / Identificador</label>
                    <input asp-for="SerialNumber" class="form-control" />
                    <span asp-validation-for="SerialNumber" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="AcquisitionDate" class="form-label">Fecha de Compra</label>
                    <input asp-for="AcquisitionDate" class="form-control" type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    <span asp-validation-for="AcquisitionDate" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="AcquisitionCost" class="form-label">Costo de Adquisición</label>
                    <input asp-for="AcquisitionCost" class="form-control" type="number" />
                    <span asp-validation-for="AcquisitionCost" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Medio de Pago (Egreso)</label>
                    <select name="paymentMethod" class="form-select" asp-items="ViewBag.PaymentMethods">
                        <option value="">-- Ninguno / Otro --</option>
                    </select>
                    <small class="text-muted">Seleccione 'Efectivo' para descontar de Caja.</small>
                </div>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Guardar Activo</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}